@page "/add-barcode"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.Data.SqlClient
@using System.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<h3>Add New Barcode</h3>

<div class="p-3 col-md-6">
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success")">@statusMessage</div>
    }

    <!-- New Barcode Input -->
    <div class="mb-3">
        <label class="form-label">New Barcode</label>
        <input @bind="newBarcode" class="form-control" placeholder="Scan or enter new barcode" />
    </div>

    <!-- Barcode Type Selection -->
    <div class="mb-3">
        <label class="form-label">Barcode Type</label>
        <select @bind="selectedBarcodeType" class="form-select">
            <option value="Piece">Piece</option>
            <option value="Pack">Pack</option>
            <option value="Case">Case</option>
        </select>
    </div>

    <!-- Add Mode Selection -->
    <div class="mb-3">
        <div class="form-check">
            <input class="form-check-input" type="radio" name="addMode" id="existingProduct" value="existing" @onchange="() => addMode = AddMode.ExistingProduct" checked="@(addMode == AddMode.ExistingProduct)" />
            <label class="form-check-label" for="existingProduct">
                Add to Existing Product
            </label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="radio" name="addMode" id="newProduct" value="new" @onchange="() => addMode = AddMode.NewProduct" />
            <label class="form-check-label" for="newProduct">
                Create New Product
            </label>
        </div>
    </div>

    <!-- Conditional UI -->
    @if (addMode == AddMode.ExistingProduct)
    {
        <div class="mb-3 position-relative">
            <label class="form-label">Select Product</label>
            <input type="text" class="form-control" placeholder="Type to search by item number or name..."
                   value="@productSearchText"
                   @oninput="OnProductSearchInput"
                   @onfocus="OnProductSearchFocus" />
            @if (selectedProductId != 0)
            {
                <small class="text-success">Selected: @productList.FirstOrDefault(p => p.ProductID == selectedProductId)?.DisplayName</small>
            }
            @if (showProductDropdown && filteredProducts.Any())
            {
                <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 250px; overflow-y: auto;">
                    @foreach (var product in filteredProducts)
                    {
                        <button type="button" class="list-group-item list-group-item-action"
                                @onclick="() => SelectProduct(product)">
                            @product.ItemNumber - @product.ProductName
                        </button>
                    }
                </div>
            }
            @if (showProductDropdown && !filteredProducts.Any() && !string.IsNullOrWhiteSpace(productSearchText))
            {
                <div class="list-group position-absolute w-100 shadow" style="z-index: 1000;">
                    <div class="list-group-item text-muted">No matching products found</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Category</label>
            <select class="form-select" value="@selectedPrefix" @onchange="OnCategoryChanged">
                <option value="">-- Select Category --</option>
                @foreach (var opt in categoryOptions)
                {
                    <option value="@opt.Prefix">@opt.DominantCategory (@opt.Prefix)</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(nextUinPreview))
            {
                <small class="text-muted">Next Universal Item Number will be: <strong>@nextUinPreview</strong></small>
            }
        </div>
        <div class="mb-3">
            <label class="form-label">Item Number</label>
            <input type="number" @bind="newItemNumber" class="form-control" placeholder="Enter Item Number" />
        </div>
        <div class="mb-3">
            <label class="form-label">Product Name</label>
            <input @bind="newProductName" class="form-control" placeholder="Enter product name" />
        </div>
        <div class="mb-3">
            <label class="form-label">Packs Per Case</label>
            <input type="number" @bind="newPacksPerCase" class="form-control" placeholder="e.g., 8" />
        </div>
        <div class="mb-3">
            <label class="form-label">Items Per Pack</label>
            <input type="number" @bind="newItemsPerPack" class="form-control" placeholder="e.g., 6" />
        </div>
        <div class="mb-3">
            <label class="form-label">DOTEXNum</label>
            <input @bind="newDotexnum" class="form-control" placeholder="Enter DOTEXNum" maxlength="32" />
        </div>
        <div class="mb-3">
            <label class="form-label">Case Weight (Kilos)</label>
            <input type="number" step="0.01" @bind="newCaseWeightKilos" class="form-control" placeholder="e.g., 12.50" />
        </div>
        <div class="mb-3">
            <label class="form-label">Product Year</label>
            <input @bind="newProductYear" @bind:after="OnProductYearChanged" class="form-control" placeholder="YYYY" />
        </div>
    }

    <button type="button" class="btn btn-primary" @onclick="HandleSave" disabled="@isSaving">
        @(isSaving ? "Saving..." : "Save Barcode")
    </button>
</div>


@code {
    private AddMode addMode = AddMode.ExistingProduct;
    private string newBarcode = "";
    private string selectedBarcodeType = "Case"; // Default value
    private int selectedProductId = 0;

    // Fields for creating a new product
    private string selectedPrefix = "";
    private string selectedCategoryName = "";
    private string nextUinPreview = "";
    private List<CategoryPrefixOption> categoryOptions = new();
    private int? newItemNumber = null;
    private string newProductName = "";
    private int? newPacksPerCase = null;
    private int? newItemsPerPack = null;
    private string newProductYear = DateTime.Now.Year.ToString();
    private string? newDotexnum = null;
    private decimal? newCaseWeightKilos = null;

    private List<Product> productList = new();
    private List<Product> filteredProducts = new();
    private string productSearchText = "";
    private bool showProductDropdown = false;
    private string statusMessage = "";
    private bool isError = false;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = DbFactory.CreateDbContext();

            // Load products for the dropdown for the current year only, ordered by ItemNumber
            var currentYear = DateTime.Now.Year.ToString();
            productList = await db.Products
                .Where(p => p.ProductYear == currentYear)
                .OrderBy(p => p.ItemNumber)
                .ToListAsync();

            categoryOptions = await LoadCategoryOptionsAsync(db, currentYear);
            newItemNumber = await GetNextItemNumberAsync(db, currentYear);
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Error loading products: {ex.Message}";
        }
    }

    private async Task<List<CategoryPrefixOption>> LoadCategoryOptionsAsync(AppDbContext db, string year)
    {
        const string sql = @"
WITH Prefixed AS (
    SELECT
        CASE
            WHEN CHARINDEX('-', UniversalItemNumber) > 0
                THEN LEFT(UniversalItemNumber, CHARINDEX('-', UniversalItemNumber) - 1)
            ELSE '(no dash)'
        END AS Prefix,
        Category
    FROM Products
    WHERE UniversalItemNumber IS NOT NULL
      AND Category IS NOT NULL
      AND ProductYear = @year
),
Ranked AS (
    SELECT Prefix, Category,
           ROW_NUMBER() OVER (PARTITION BY Prefix ORDER BY COUNT(*) DESC) AS rn
    FROM Prefixed
    GROUP BY Prefix, Category
)
SELECT Prefix, Category AS DominantCategory
FROM Ranked
WHERE rn = 1
ORDER BY DominantCategory;";

        return await db.Database
            .SqlQueryRaw<CategoryPrefixOption>(sql, new SqlParameter("@year", year))
            .ToListAsync();
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        selectedPrefix = e.Value?.ToString() ?? "";
        var match = categoryOptions.FirstOrDefault(o => o.Prefix == selectedPrefix);
        selectedCategoryName = match?.DominantCategory ?? "";

        if (string.IsNullOrEmpty(selectedPrefix))
        {
            nextUinPreview = "";
            return;
        }

        await using var db = DbFactory.CreateDbContext();
        var (num, width) = await GetNextUinAsync(db, selectedPrefix);
        nextUinPreview = FormatUin(selectedPrefix, num, width);
    }

    private async Task<(int NextNum, int Width)> GetNextUinAsync(AppDbContext db, string prefix)
    {
        const string sql = @"
WITH Numbered AS (
    SELECT
        TRY_CAST(SUBSTRING(UniversalItemNumber, LEN(@prefix) + 2, 100) AS INT) AS Num,
        LEN(UniversalItemNumber) - LEN(@prefix) - 1 AS NumWidth
    FROM Products
    WHERE UniversalItemNumber LIKE @prefix + '-%'
)
SELECT TOP 1 Num, NumWidth
FROM Numbered
WHERE Num IS NOT NULL
ORDER BY Num DESC;";

        var row = (await db.Database
            .SqlQueryRaw<NextUinRow>(sql, new SqlParameter("@prefix", prefix))
            .ToListAsync()).FirstOrDefault();

        if (row == null || row.Num == null)
        {
            return (1, 3);
        }
        return (row.Num.Value + 1, row.NumWidth ?? 3);
    }

    private static string FormatUin(string prefix, int number, int width)
    {
        var padded = number.ToString().PadLeft(width, '0');
        return $"{prefix}-{padded}";
    }

    private async Task<int> GetNextItemNumberAsync(AppDbContext db, string year)
    {
        const string sql = @"
SELECT ISNULL(MAX(ItemNumber), 0) + 1 AS Value
FROM Products
WHERE ProductYear = @year;";

        var rows = await db.Database
            .SqlQueryRaw<int>(sql, new SqlParameter("@year", year))
            .ToListAsync();
        return rows.FirstOrDefault();
    }

    private async Task OnProductYearChanged()
    {
        if (string.IsNullOrWhiteSpace(newProductYear) || newProductYear.Length != 4)
        {
            return;
        }
        await using var db = DbFactory.CreateDbContext();
        newItemNumber = await GetNextItemNumberAsync(db, newProductYear);
    }

    private void OnProductSearchInput(ChangeEventArgs e)
    {
        productSearchText = e.Value?.ToString() ?? "";
        selectedProductId = 0;
        if (string.IsNullOrWhiteSpace(productSearchText))
        {
            filteredProducts = new();
            showProductDropdown = false;
        }
        else
        {
            filteredProducts = productList
                .Where(p => (p.ItemNumber?.ToString().Contains(productSearchText, StringComparison.OrdinalIgnoreCase) ?? false)
                          || (p.ProductName?.Contains(productSearchText, StringComparison.OrdinalIgnoreCase) ?? false))
                .Take(20)
                .ToList();
            showProductDropdown = true;
        }
    }

    private void OnProductSearchFocus()
    {
        if (!string.IsNullOrWhiteSpace(productSearchText) && filteredProducts.Any())
        {
            showProductDropdown = true;
        }
    }

    private void SelectProduct(Product product)
    {
        selectedProductId = product.ProductID;
        productSearchText = $"{product.ItemNumber} - {product.ProductName}";
        showProductDropdown = false;
        filteredProducts = new();
    }

    private async Task HandleSave()
    {
        statusMessage = "";
        isError = false;

        if (string.IsNullOrWhiteSpace(newBarcode))
        {
            isError = true;
            statusMessage = "Barcode cannot be empty.";
            return;
        }

        isSaving = true;
        try
        {
            if (addMode == AddMode.ExistingProduct)
            {
                await AddBarcodeToExistingProduct();
            }
            else
            {
                await AddBarcodeToNewProduct();
            }
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Error saving: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task AddBarcodeToExistingProduct()
    {
        if (selectedProductId == 0)
        {
            isError = true;
            statusMessage = "You must select an existing product.";
            return;
        }

        await using var db = DbFactory.CreateDbContext();

        // Fetch only the UniversalItemNumber string.
        var universalItemNum = await db.Products
            .Where(p => p.ProductID == selectedProductId)
            .Select(p => p.UniversalItemNumber)
            .FirstOrDefaultAsync();

        if (string.IsNullOrEmpty(universalItemNum))
        {
            isError = true;
            statusMessage = "Selected product not found or has no Universal Item Number.";
            return;
        }

        // Using a raw SQL command to bypass the faulty EF Core relationship mapping.
        await db.Database.ExecuteSqlRawAsync(
            "INSERT INTO Barcodes (BarCode, UniversalItemNumber, BarcodeType) VALUES ({0}, {1}, {2})",
            newBarcode,
            universalItemNum,
            selectedBarcodeType
        );

        statusMessage = $"Successfully added barcode '{newBarcode}'.";
        ResetForm();
    }

    private async Task AddBarcodeToNewProduct()
    {
        // --- Validation for new fields ---
        if (string.IsNullOrWhiteSpace(selectedPrefix))
        {
            isError = true;
            statusMessage = "Category is required.";
            return;
        }
        if (newItemNumber == null)
        {
            isError = true;
            statusMessage = "Item Number cannot be empty.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newProductName))
        {
            isError = true;
            statusMessage = "New product name cannot be empty.";
            return;
        }
        if (newPacksPerCase == null || newPacksPerCase <= 0)
        {
            isError = true;
            statusMessage = "Packs Per Case is required and must be greater than 0.";
            return;
        }
        if (newItemsPerPack == null || newItemsPerPack <= 0)
        {
            isError = true;
            statusMessage = "Items Per Pack is required and must be greater than 0.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newProductYear) || newProductYear.Length != 4)
        {
            isError = true;
            statusMessage = "Product Year must be a 4-digit year.";
            return;
        }

        // Wrap the next-UIN derivation, product insert, and barcode insert in a
        // serializable transaction so two concurrent scans cannot allocate the
        // same UIN.
        await using var db = DbFactory.CreateDbContext();
        await using var tx = await db.Database.BeginTransactionAsync(IsolationLevel.Serializable);

        var (nextNum, width) = await GetNextUinAsync(db, selectedPrefix);
        var derivedUin = FormatUin(selectedPrefix, nextNum, width);

        var newProduct = new Product
        {
            UniversalItemNumber = derivedUin,
            Category = selectedCategoryName,
            ItemNumber = newItemNumber.Value,
            ProductName = newProductName,
            ProductYear = newProductYear,
            PacksPerCase = newPacksPerCase,
            ItemsPerPack = newItemsPerPack,
            Dotexnum = newDotexnum,
            CaseWeightKilos = newCaseWeightKilos,
            QtyInStock = 0,
            QuantityInStock = 0
        };

        db.Products.Add(newProduct);
        await db.SaveChangesAsync();

        await db.Database.ExecuteSqlRawAsync(
            "INSERT INTO Barcodes (BarCode, UniversalItemNumber, BarcodeType) VALUES ({0}, {1}, {2})",
            newBarcode,
            newProduct.UniversalItemNumber!,
            selectedBarcodeType
        );

        await tx.CommitAsync();

        statusMessage = $"Successfully created product '{newProduct.ProductName}' as {derivedUin} and added barcode '{newBarcode}'.";

        // Refresh product list and category options (a fresh prefix may now have a category)
        var currentYear = DateTime.Now.Year.ToString();
        productList = await db.Products
            .Where(p => p.ProductYear == currentYear)
            .OrderBy(p => p.ItemNumber)
            .ToListAsync();
        categoryOptions = await LoadCategoryOptionsAsync(db, currentYear);
        ResetForm();
        newItemNumber = await GetNextItemNumberAsync(db, newProductYear);
    }

    private void ResetForm()
    {
        newBarcode = "";
        selectedProductId = 0;
        productSearchText = "";
        filteredProducts = new();
        showProductDropdown = false;
        selectedPrefix = "";
        selectedCategoryName = "";
        nextUinPreview = "";
        newItemNumber = null;
        newProductName = "";
        newPacksPerCase = null;
        newItemsPerPack = null;
        newDotexnum = null;
        newCaseWeightKilos = null;
        newProductYear = DateTime.Now.Year.ToString();
        selectedBarcodeType = "Piece"; // Reset barcode type
    }

    private enum AddMode { ExistingProduct, NewProduct }

    public class CategoryPrefixOption
    {
        public string Prefix { get; set; } = "";
        public string DominantCategory { get; set; } = "";
    }

    public class NextUinRow
    {
        public int? Num { get; set; }
        public int? NumWidth { get; set; }
    }
}
