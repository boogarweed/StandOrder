@page "/pull-order/{OrdersTakenID:int}"
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Pull Order</PageTitle>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success text-center mt-5">
        <h4 class="alert-heading">Order Completed!</h4>
        <p>@successMessage</p>
        <hr>
        <button class="btn btn-primary" @onclick="GoToOrdersList">
            Return to Orders List
        </button>
    </div>
}
else if (orderViewModel == null)
{
    <p><em>Loading Order...</em></p>
}
else
{
    <h1 class="mb-4">Order Details for @orderViewModel.CustomerName - @orderViewModel.TypeOrder Order</h1>

    <div class="mb-3 d-flex justify-content-between align-items-center">
        <div>
            <strong>Sort by:</strong>
            <button class="btn btn-secondary btn-sm @(currentSort == "ItemNumber" ? "active" : "")" @onclick='() => SortDetailsBy("ItemNumber")'>Item #</button>
            <button class="btn btn-secondary btn-sm @(currentSort == "WarehouseLocation" ? "active" : "")" @onclick='() => SortDetailsBy("WarehouseLocation")'>Location</button>
        </div>
        <button class="btn btn-primary" @onclick="OpenAddItemModal">+ Add Item</button>
    </div>

    @if (showAddItemModal)
    {
        <div class="modal fade show" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Add Item to Order</h5>
                        <button type="button" class="btn-close" @onclick="CloseAddItemModal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label"><strong>Scan Barcode</strong></label>
                            <input type="text" class="form-control" placeholder="Scan a barcode..."
                                   @ref="barcodeInput"
                                   enterkeyhint="done" autocomplete="off"
                                   autocapitalize="off" autocorrect="off" spellcheck="false" />
                        </div>

                        <div class="mb-3 position-relative">
                            <label class="form-label"><strong>Or Search by Item # / Name</strong></label>
                            <input type="text" class="form-control" placeholder="Type to search..."
                                   value="@productSearchText"
                                   @oninput="OnProductSearchInput"
                                   @onfocus="OnProductSearchFocus" />
                            @if (addItemSelectedProduct != null)
                            {
                                <small class="text-success">Selected: @addItemSelectedProduct.ItemNumber - @addItemSelectedProduct.ProductName</small>
                            }
                            @if (showProductDropdown && filteredProducts.Any())
                            {
                                <div class="list-group position-absolute w-100 shadow" style="z-index: 1060; max-height: 250px; overflow-y: auto;">
                                    @foreach (var product in filteredProducts)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action"
                                                @onclick="() => SelectProductForAdd(product)">
                                            @product.ItemNumber - @product.ProductName
                                        </button>
                                    }
                                </div>
                            }
                            @if (showProductDropdown && !filteredProducts.Any() && !string.IsNullOrWhiteSpace(productSearchText))
                            {
                                <div class="list-group position-absolute w-100 shadow" style="z-index: 1060;">
                                    <div class="list-group-item text-muted">No matching products found</div>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(addItemError))
                        {
                            <div class="alert alert-danger">@addItemError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddItemModal">Cancel</button>
                        <button type="button" class="btn btn-success" @onclick="ConfirmAddItem" disabled="@(addItemSelectedProduct == null)">Add to Order</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="table-scroll">
    <table class="table">
        <thead>
            <tr>
                <th>Item Num</th>
                <th>Location</th>
                <th>Item Name/Notes</th>
                <th>Case Pack</th>
                <th>Cases In Stock</th>
                <th>Qty Ordered</th>
                <th>Qty Pulled</th>
                <th style="width: 1%; white-space: nowrap;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var detail in orderViewModel.Details)
            {
                <tr id="detail-row-@detail.OrdersTakenDetailsID" class="@(highlightedDetailId == detail.OrdersTakenDetailsID ? "table-danger" : "")">
                    <td>@detail.ItemNumber</td>
                    <td>@detail.WarehouseLocation</td>
                    <td>
                        <div>@detail.ProductName</div>
                        @if (!string.IsNullOrWhiteSpace(detail.Notes))
                        {
                            <div class="text-muted fst-italic small">@detail.Notes</div>
                        }
                    </td>
                    <td>@detail.PacksPerCase</td>
                    <td>@detail.QtyInStockDisplay</td>
                    <td>@detail.QuantityOrdered</td>
                    <td>
                        <input type="number" class="form-control" style="max-width: 100px;" readonly value="@detail.QuantityPulled" />
                    </td>
                    <td>
                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="button" class="btn btn-success btn-sm flex-fill" @onclick="() => UpdateQuantityPulled(detail, detail.QuantityOrdered)">Pulled</button>
                            <button type="button" class="btn btn-info btn-sm flex-fill" @onclick="() => PromptForOtherQuantity(detail)">Other</button>
                            <button type="button" class="btn btn-warning btn-sm flex-fill" @onclick="() => UpdateQuantityPulled(detail, 0)">None</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <hr />

    <div class="mt-4">
        <button class="btn btn-primary" @onclick="PullAll">Pull All</button>
        <button class="btn btn-success" @onclick="CompleteOrder">Complete Order</button>
    </div>
}

<style>
    /* Bound the table to its own scroll region and pin the header to the top of
       that region. An explicit overflow container makes `position: sticky`
       reliable on every browser, including older Android WebView, where
       page-level sticky table cells don't anchor. Delivered inline so it can't
       be served from a stale CSS-bundle cache. */
    .table-scroll {
        max-height: calc(100vh - 14rem);
        overflow-y: auto;
    }

    /* Bootstrap's Reboot collapses table borders; Chromium ignores sticky on
       collapsed cells, so use separate borders for this table. */
    .table-scroll > .table {
        border-collapse: separate;
        border-spacing: 0;
        margin-bottom: 0;
    }

    .table-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background-color: #fff;
        box-shadow: inset 0 -1px 0 #dee2e6;
    }
</style>

<script>
    // Buffer barcode keystrokes in the browser (no per-key server round-trips).
    // The input fills natively; the scan is submitted to .NET in a single call.
    // We cancel the scanner's "Enter" several ways because Android/Samsung
    // devices deliver it inconsistently: as a keydown, as a keypress, or even
    // as a literal newline injected into the text (which moves focus to the
    // next field before any cancelable key event fires).
    window.pullOrderBarcode = {
        register: function (inputEl, dotNetRef) {
            if (!inputEl) return;
            if (inputEl._barcodeCleanup) inputEl._barcodeCleanup();

            const submit = function () {
                const code = inputEl.value.replace(/[\r\n\t]/g, '');
                inputEl.value = '';
                if (code.length > 0) {
                    dotNetRef.invokeMethodAsync('OnBarcodeScanned', code);
                }
            };

            const isSubmitKey = function (e) {
                return e.key === 'Enter' || e.key === 'Tab' ||
                       e.keyCode === 13 || e.keyCode === 9 ||
                       e.which === 13 || e.which === 9;
            };

            // Cancel the focus-move on every phase the key might surface in.
            const keyHandler = function (e) {
                if (isSubmitKey(e)) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (e.type === 'keydown') submit();
                }
            };

            // Fallback: scanner delivered Enter as a newline character in the value.
            const inputHandler = function () {
                if (/[\r\n\t]/.test(inputEl.value)) submit();
            };

            inputEl.addEventListener('keydown', keyHandler, true);
            inputEl.addEventListener('keypress', keyHandler, true);
            inputEl.addEventListener('keyup', keyHandler, true);
            inputEl.addEventListener('input', inputHandler);

            inputEl._barcodeCleanup = function () {
                inputEl.removeEventListener('keydown', keyHandler, true);
                inputEl.removeEventListener('keypress', keyHandler, true);
                inputEl.removeEventListener('keyup', keyHandler, true);
                inputEl.removeEventListener('input', inputHandler);
                inputEl._barcodeCleanup = null;
            };

            inputEl.focus();
        },
        focus: function (inputEl) {
            if (inputEl) inputEl.focus();
        }
    };
</script>

@code {
    [Parameter]
    public int OrdersTakenID { get; set; }

    private OrderPullModel orderViewModel;
    private string successMessage;
    private string currentSort = "ItemNumber";
    private int? highlightedDetailId = null;

    // Add Item modal state
    private bool showAddItemModal = false;
    private ElementReference barcodeInput;
    private DotNetObjectReference<PullOrder>? _objRef;
    private bool shouldFocusBarcode = false;
    private string productSearchText = "";
    private List<Product> allProducts = new();
    private List<Product> filteredProducts = new();
    private bool showProductDropdown = false;
    private Product? addItemSelectedProduct = null;
    private string addItemError = "";

    // --- View Models for this specific page ---
    public class OrderPullModel
    {
        public int OrdersTakenID { get; set; }
        public string CustomerName { get; set; }
        public string TypeOrder { get; set; }
        public List<OrderDetailPullModel> Details { get; set; } = new();
    }

    public class OrderDetailPullModel
    {
        public int OrdersTakenDetailsID { get; set; }
        public int? ItemNumber { get; set; }
        public string ProductName { get; set; }
        public int? PacksPerCase { get; set; }
        public string WarehouseLocation { get; set; }
        public int? QuantityInStock { get; set; }
        public int? ItemsPerPack { get; set; }
        public int QuantityOrdered { get; set; }
        public int? QuantityPulled { get; set; }
        public string Notes { get; set; }

        public string QtyInStockDisplay
        {
            get
            {
                if (QuantityInStock == null || PacksPerCase == null || ItemsPerPack == null
                    || PacksPerCase == 0 || ItemsPerPack == 0)
                    return "N/A";
                return ((decimal)QuantityInStock.Value / PacksPerCase.Value / ItemsPerPack.Value).ToString("F2");
            }
        }
    }

    private void GoToOrdersList()
    {
        NavigationManager.NavigateTo("/orders-to-be-pulled");
    }

    protected override async Task OnInitializedAsync()
    {
        // Get the header info (Customer Name, Order Type) first
        var orderHeader = await DbContext.OrdersTakens
            .Where(o => o.OrdersTakenID == OrdersTakenID)
            .Join(DbContext.Customers, o => o.CustomerID, c => c.CustomerID, (o, c) => new { o.TypeOrder, c.FullName })
            .FirstOrDefaultAsync();

        if (orderHeader == null) return;

        // Now, get the details by joining OrdersTakenDetails with Products
        var details = await DbContext.OrdersTakenDetails
            .Where(d => d.OrdersTakenID == OrdersTakenID)
            .Join(DbContext.Products, d => d.ProductID, p => p.ProductID, (detail, product) => new OrderDetailPullModel
            {
                OrdersTakenDetailsID = detail.OrdersTakenDetailsID,
                ItemNumber = product.ItemNumber,
                ProductName = product.ProductName,
                PacksPerCase = product.PacksPerCase,
                WarehouseLocation = product.WarehouseLocation,
                QuantityInStock = product.QuantityInStock,
                ItemsPerPack = product.ItemsPerPack,
                QuantityOrdered = detail.QuantityOrdered,
                QuantityPulled = detail.QuantityPulled,
                Notes = detail.Notes
            })
            .ToListAsync();

        // Combine into the final view model
        orderViewModel = new OrderPullModel
        {
            OrdersTakenID = this.OrdersTakenID,
            CustomerName = orderHeader.FullName,
            TypeOrder = orderHeader.TypeOrder,
            Details = details
        };

        // Load current-year products for the Add Item search
        var currentYear = DateTime.Now.Year.ToString();
        allProducts = await DbContext.Products
            .Where(p => p.ProductYear == currentYear)
            .OrderBy(p => p.ItemNumber)
            .ToListAsync();

        SortDetailsBy(currentSort); // Apply initial sort
    }

    // ---------- Add Item modal ----------

    private void OpenAddItemModal()
    {
        showAddItemModal = true;
        shouldFocusBarcode = true; // Register the JS handler + focus once the modal renders
        productSearchText = "";
        filteredProducts = new();
        showProductDropdown = false;
        addItemSelectedProduct = null;
        addItemError = "";
    }

    private void CloseAddItemModal()
    {
        showAddItemModal = false;
        productSearchText = "";
        filteredProducts = new();
        showProductDropdown = false;
        addItemSelectedProduct = null;
        addItemError = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldFocusBarcode)
        {
            shouldFocusBarcode = false;
            _objRef ??= DotNetObjectReference.Create(this);
            // Attaches the Enter-to-submit keydown listener and focuses the box.
            try { await JSRuntime.InvokeVoidAsync("pullOrderBarcode.register", barcodeInput, _objRef); } catch { }
        }
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    // Called from JS once the scanner sends Enter, with the full barcode the
    // browser collected natively (no per-keystroke server round-trips).
    [JSInvokable]
    public async Task OnBarcodeScanned(string scannedCode)
    {
        var code = scannedCode?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(code))
        {
            StateHasChanged();
            return;
        }

        addItemError = "";
        var currentYear = DateTime.Now.Year.ToString();
        var matchingProducts = await (
            from b in DbContext.Barcodes
            join p in DbContext.Products on b.UniversalItemNumber equals p.UniversalItemNumber
            where b.BarCode == code && p.ProductYear == currentYear
            select p
        ).ToListAsync();

        if (matchingProducts.Count == 0)
        {
            addItemError = $"No product found for barcode '{code}'.";
            addItemSelectedProduct = null;
        }
        else if (matchingProducts.Count == 1 ||
                 matchingProducts.All(p => p.UniversalItemNumber == matchingProducts.First().UniversalItemNumber))
        {
            SelectProductForAdd(matchingProducts.First());
        }
        else
        {
            addItemError = $"Barcode '{code}' matches multiple distinct products. Use the search box instead.";
        }

        // JSInvokable methods don't trigger a render automatically.
        StateHasChanged();

        // Keep focus on the barcode box so the next scan lands here.
        try { await JSRuntime.InvokeVoidAsync("pullOrderBarcode.focus", barcodeInput); } catch { }
    }

    private void OnProductSearchInput(ChangeEventArgs e)
    {
        productSearchText = e.Value?.ToString() ?? "";
        addItemSelectedProduct = null;
        if (string.IsNullOrWhiteSpace(productSearchText))
        {
            filteredProducts = new();
            showProductDropdown = false;
        }
        else
        {
            filteredProducts = allProducts
                .Where(p => (p.ItemNumber?.ToString().Contains(productSearchText, StringComparison.OrdinalIgnoreCase) ?? false)
                          || (p.ProductName?.Contains(productSearchText, StringComparison.OrdinalIgnoreCase) ?? false))
                .Take(20)
                .ToList();
            showProductDropdown = true;
        }
    }

    private void OnProductSearchFocus()
    {
        if (!string.IsNullOrWhiteSpace(productSearchText) && filteredProducts.Any())
        {
            showProductDropdown = true;
        }
    }

    private void SelectProductForAdd(Product product)
    {
        addItemSelectedProduct = product;
        productSearchText = $"{product.ItemNumber} - {product.ProductName}";
        showProductDropdown = false;
        filteredProducts = new();
        addItemError = "";
    }

    private async Task ConfirmAddItem()
    {
        if (addItemSelectedProduct == null) return;

        // Prompt for quantity
        var input = await JSRuntime.InvokeAsync<string>("prompt", $"Enter the quantity ordered for '{addItemSelectedProduct.ProductName}':", "1");
        if (string.IsNullOrWhiteSpace(input)) return; // User canceled

        if (!int.TryParse(input, out int quantity) || quantity <= 0)
        {
            addItemError = "Please enter a valid quantity greater than zero.";
            return;
        }

        // Check if this product is already on the order
        var existingDetail = await DbContext.OrdersTakenDetails
            .FirstOrDefaultAsync(d => d.OrdersTakenID == OrdersTakenID && d.ProductID == addItemSelectedProduct.ProductID);

        if (existingDetail != null)
        {
            addItemError = $"'{addItemSelectedProduct.ProductName}' is already on this order.";
            return;
        }

        // Insert a new OrdersTakenDetails row
        var newDetail = new OrdersTakenDetails
        {
            OrdersTakenID = OrdersTakenID,
            ProductID = addItemSelectedProduct.ProductID,
            QuantityOrdered = quantity,
            QuantityPulled = null
        };

        DbContext.OrdersTakenDetails.Add(newDetail);
        await DbContext.SaveChangesAsync();

        // Add to the view model so the table updates without a full reload
        orderViewModel.Details.Add(new OrderDetailPullModel
        {
            OrdersTakenDetailsID = newDetail.OrdersTakenDetailsID,
            ItemNumber = addItemSelectedProduct.ItemNumber,
            ProductName = addItemSelectedProduct.ProductName,
            PacksPerCase = addItemSelectedProduct.PacksPerCase,
            WarehouseLocation = addItemSelectedProduct.WarehouseLocation,
            QuantityInStock = addItemSelectedProduct.QuantityInStock,
            ItemsPerPack = addItemSelectedProduct.ItemsPerPack,
            QuantityOrdered = quantity,
            QuantityPulled = null
        });

        SortDetailsBy(currentSort);
        CloseAddItemModal();
        StateHasChanged();
    }

    private void SortDetailsBy(string sortKey)
    {
        currentSort = sortKey;
        if (orderViewModel?.Details != null)
        {
            if (sortKey == "WarehouseLocation")
            {
                orderViewModel.Details = orderViewModel.Details.OrderBy(d => d.WarehouseLocation).ToList();
            }
            else // Default to ItemNumber
            {
                orderViewModel.Details = orderViewModel.Details.OrderBy(d => d.ItemNumber).ToList();
            }
        }
    }

    private async Task UpdateQuantityPulled(OrderDetailPullModel detailModel, int newQuantity)
    {
        // Inventory in the Products table (QuantityInStock) is updated via a trigger on the OrdersTakenDetails table
        var detailInDb = await DbContext.OrdersTakenDetails.FindAsync(detailModel.OrdersTakenDetailsID);
        if (detailInDb != null)
        {
            detailInDb.QuantityPulled = newQuantity;
            await DbContext.SaveChangesAsync();
            detailModel.QuantityPulled = newQuantity; // Update the UI model
            StateHasChanged();
        }
    }

    private async Task PromptForOtherQuantity(OrderDetailPullModel detailModel)
    {
        var result = await JSRuntime.InvokeAsync<string>("prompt", "Enter the quantity pulled:", detailModel.QuantityPulled ?? 0);
        if (int.TryParse(result, out int newQuantity))
        {
            await UpdateQuantityPulled(detailModel, newQuantity);
        }
    }

    private async Task PullAll()
    {
        foreach (var detailModel in orderViewModel.Details)
        {
            var detailInDb = await DbContext.OrdersTakenDetails.FindAsync(detailModel.OrdersTakenDetailsID);
            if (detailInDb != null)
            {
                detailInDb.QuantityPulled = detailInDb.QuantityOrdered;
            }
        }
        await DbContext.SaveChangesAsync();
        orderViewModel.Details.ForEach(d => d.QuantityPulled = d.QuantityOrdered);
        StateHasChanged();
    }

    private async Task CompleteOrder()
    {
        // Clear any previous highlight
        highlightedDetailId = null;

        // 1. Check for the first item where 'Qty Pulled' is not filled in.
        var firstIncompleteDetail = orderViewModel.Details
            .FirstOrDefault(d => d.QuantityPulled == null);

        if (firstIncompleteDetail != null)
        {
            // 2. Highlight the row via Blazor state and scroll to it.
            highlightedDetailId = firstIncompleteDetail.OrdersTakenDetailsID;
            StateHasChanged();

            try
            {
                await JSRuntime.InvokeVoidAsync("alert", "Please fill in all 'Qty Pulled' values before completing the order.");
                await JSRuntime.InvokeVoidAsync("eval",
                    $"document.getElementById('detail-row-{firstIncompleteDetail.OrdersTakenDetailsID}')?.scrollIntoView({{behavior:'smooth',block:'center'}})");
            }
            catch
            {
                // Ignore JS interop errors so the circuit stays alive.
            }

            return;
        }

        // 3. If all items are valid, proceed with completing the order.
        try
        {
            var orderInDb = await DbContext.OrdersTakens.FindAsync(OrdersTakenID);
            if (orderInDb != null)
            {
                orderInDb.Status = "Pulled";
                await DbContext.SaveChangesAsync();
                successMessage = "The order status has been successfully updated to 'Pulled'.";
            }
        }
        catch (Exception ex)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error completing order: {ex.Message}");
            }
            catch { }
        }
    }
}