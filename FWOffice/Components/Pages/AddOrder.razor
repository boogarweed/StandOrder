@page "/orders/new"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using System.Data
@using ExcelDataReader
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Add Order</PageTitle>

<h1 class="mb-3">Add Order</h1>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">@statusMessage</div>
}

<div class="row g-3 mb-3">
    <div class="col-md-6 position-relative">
        <label class="form-label">Customer <span class="text-danger">*</span></label>
        @if (selectedCustomerId == null)
        {
            <input class="form-control" placeholder="Search customer by name or business..."
                   value="@custSearchText" @oninput="OnCustSearch" />
            @if (custResults.Any())
            {
                <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 300px; overflow-y: auto;">
                    @foreach (var c in custResults)
                    {
                        <button type="button" class="list-group-item list-group-item-action"
                                @onclick="() => SelectCustomer(c)">
                            <strong>@c.FullName</strong>
                            @if (!string.IsNullOrWhiteSpace(c.BusinessName))
                            {
                                <span class="text-muted"> — @c.BusinessName</span>
                            }
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <div class="input-group">
                <input class="form-control" value="@selectedCustomerName" readonly />
                <button class="btn btn-outline-secondary" @onclick="ClearCustomer">Change</button>
            </div>
        }
    </div>

    <div class="col-md-2">
        <label class="form-label">Year</label>
        <input type="number" class="form-control" @bind="year" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Type <span class="text-danger">*</span></label>
        <select class="form-select" @bind="typeOrder">
            <option value="Case">Case</option>
            <option value="Broken">Broken</option>
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">Pick-Up Date</label>
        <input type="date" class="form-control" @bind="pickupDate" @bind:format="yyyy-MM-dd" />
    </div>
</div>

<details class="mb-3">
    <summary class="fw-semibold">Same As Last Year</summary>
    <div class="border rounded p-3 mt-2">
        @if (selectedCustomerId == null)
        {
            <div class="text-muted">Select a customer first.</div>
        }
        else
        {
            <div class="row g-2 mb-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Look at year</label>
                    <input type="number" class="form-control" style="max-width: 8rem;" @bind="salyYear" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-secondary" @onclick="LoadSalyInvoices">Find invoices</button>
                </div>
            </div>

            @if (salyInvoices.Any())
            {
                <div class="table-responsive" style="max-height: 260px; overflow: auto;">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr><th>Invoice #</th><th>Date</th><th>Order Total</th><th>Net Total</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in salyInvoices)
                            {
                                <tr>
                                    <td>@inv.OrderId</td>
                                    <td>@inv.OrderDate.ToString("MM/dd/yyyy")</td>
                                    <td>@inv.OrderTotal?.ToString("C")</td>
                                    <td>@inv.NetTotal?.ToString("C")</td>
                                    <td><button class="btn btn-sm btn-outline-primary" @onclick="() => ApplySaly(inv.OrderId)">Use this</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (salyLoaded)
            {
                <div class="text-muted">No invoices found for @salyYear.</div>
            }

            @if (!string.IsNullOrEmpty(salyMsg))
            {
                <div class="alert alert-info mt-2 mb-0">@salyMsg</div>
            }
        }
    </div>
</details>

<details class="mb-3">
    <summary class="fw-semibold">Import items from Excel</summary>
    <div class="border rounded p-3 mt-2">
        @if (selectedCustomerId == null)
        {
            <div class="text-muted">Select a customer first.</div>
        }
        else
        {
            <InputFile OnChange="OnImportFile" accept=".xls,.xlsx" class="form-control mb-3" />

            @if (importCols > 0)
            {
                <div class="row g-2 mb-2">
                    <div class="col-auto">
                        <label class="form-label">Header rows to skip</label>
                        <input type="number" min="0" class="form-control" style="max-width: 7rem;" @bind="skipRows" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label">Match column</label>
                        <select class="form-select" @bind="matchCol">
                            @for (int c = 0; c < importCols; c++)
                            {
                                <option value="@c">@ColLabel(c) — @SampleValue(c)</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label">Match by</label>
                        <select class="form-select" @bind="matchBy">
                            <option value="ItemNumber">Item Number</option>
                            <option value="UniversalItemNumber">UIN</option>
                            <option value="ProductName">Product Name</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label">Quantity column</label>
                        <select class="form-select" @bind="qtyCol">
                            @for (int c = 0; c < importCols; c++)
                            {
                                <option value="@c">@ColLabel(c) — @SampleValue(c)</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="table-responsive mb-2" style="max-height: 220px; overflow: auto;">
                    <table class="table table-sm table-bordered small mb-0">
                        <thead>
                            <tr>
                                @for (int c = 0; c < importCols; c++)
                                {
                                    <th>@ColLabel(c)</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in importRows.Take(6))
                            {
                                <tr>
                                    @for (int c = 0; c < importCols; c++)
                                    {
                                        <td>@CellText(r, c)</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <button class="btn btn-outline-primary" @onclick="ApplyImport">Apply Import</button>
            }

            @if (!string.IsNullOrEmpty(importMsg))
            {
                <div class="alert alert-info mt-2 mb-0">@importMsg</div>
            }
        }
    </div>
</details>

<h4 class="mt-3">Items</h4>
<div class="row mb-2">
    <div class="col-md-6 position-relative">
        <input class="form-control" placeholder="Add item — search by item # or name..."
               value="@addSearchText" @oninput="OnAddSearch" disabled="@(selectedCustomerId == null)" />
        @if (addResults.Any())
        {
            <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 250px; overflow-y: auto;">
                @foreach (var p in addResults)
                {
                    <button type="button" class="list-group-item list-group-item-action"
                            @onclick="() => AddProduct(p)">
                        @p.ItemNumber - @p.ProductName
                    </button>
                }
            </div>
        }
    </div>
    @if (selectedCustomerId == null)
    {
        <div class="col-md-6 d-flex align-items-center text-muted">Select a customer first.</div>
    }
</div>

<div class="table-responsive">
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Item #</th>
                <th>Product</th>
                <th style="width: 8rem;">Quantity</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!lines.Any())
            {
                <tr><td colspan="5" class="text-muted">No items yet.</td></tr>
            }
            @foreach (var line in lines)
            {
                <tr>
                    <td>@line.ItemNumber</td>
                    <td>@line.ProductName</td>
                    <td><input type="number" class="form-control form-control-sm" @bind="line.Qty" /></td>
                    <td><input class="form-control form-control-sm" @bind="line.Notes" /></td>
                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => lines.Remove(line)">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3 mb-5">
    <button class="btn btn-success" @onclick="Save" disabled="@isSaving">@(isSaving ? "Saving..." : "Save Order")</button>
    <button class="btn btn-secondary" @onclick="@(() => Nav.NavigateTo("/orders"))" disabled="@isSaving">Cancel</button>
</div>

@code {
    private int? selectedCustomerId;
    private string selectedCustomerName = "";
    private string custSearchText = "";
    private List<Customer> custResults = new();

    private int year = DateTime.Today.Year;
    private string typeOrder = "Case";
    private DateTime pickupDate = DateTime.Today;

    private string addSearchText = "";
    private List<Product> addResults = new();
    private List<NewLine> lines = new();

    private string statusMessage = "";
    private bool isError = false;
    private bool isSaving = false;

    private class NewLine
    {
        public int ProductId { get; set; }
        public int? ItemNumber { get; set; }
        public string? ProductName { get; set; }
        public int Qty { get; set; } = 1;
        public string? Notes { get; set; }
    }

    private async Task OnCustSearch(ChangeEventArgs e)
    {
        custSearchText = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(custSearchText)) { custResults = new(); return; }
        var term = custSearchText.Trim();
        await using var db = DbFactory.CreateDbContext();
        custResults = await db.Customers
            .Where(c => (c.FullName != null && c.FullName.Contains(term))
                     || (c.LastName != null && c.LastName.Contains(term))
                     || (c.BusinessName != null && c.BusinessName.Contains(term)))
            .OrderBy(c => c.LastName).Take(25).AsNoTracking().ToListAsync();
    }

    private void SelectCustomer(Customer c)
    {
        selectedCustomerId = c.CustomerID;
        selectedCustomerName = c.FullName ?? "";
        custResults = new();
        custSearchText = "";
    }

    private void ClearCustomer()
    {
        selectedCustomerId = null;
        selectedCustomerName = "";
        addResults = new();
        addSearchText = "";
    }

    private async Task OnAddSearch(ChangeEventArgs e)
    {
        addSearchText = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(addSearchText)) { addResults = new(); return; }
        var term = addSearchText.Trim();
        var yearStr = year.ToString();
        await using var db = DbFactory.CreateDbContext();
        addResults = await db.Products
            .Where(p => p.ProductYear == yearStr
                     && ((p.ItemNumber != null && p.ItemNumber.ToString()!.Contains(term))
                       || (p.ProductName != null && p.ProductName.Contains(term))))
            .OrderBy(p => p.ItemNumber).Take(25).AsNoTracking().ToListAsync();
    }

    private void AddProduct(Product p)
    {
        addResults = new();
        addSearchText = "";
        if (lines.Any(l => l.ProductId == p.ProductID))
        {
            isError = true;
            statusMessage = $"{p.ProductName} is already on the order.";
            return;
        }
        lines.Add(new NewLine { ProductId = p.ProductID, ItemNumber = p.ItemNumber, ProductName = p.ProductName });
        statusMessage = "";
    }

    // ---- Same As Last Year (copy a prior-year invoice, mapped by UIN) ----
    private int salyYear = DateTime.Today.Year - 1;
    private bool salyLoaded = false;
    private string salyMsg = "";
    private List<SalyInvoice> salyInvoices = new();
    private record SalyInvoice(int OrderId, DateTime OrderDate, decimal? OrderTotal, decimal? NetTotal);

    private async Task LoadSalyInvoices()
    {
        salyMsg = "";
        salyLoaded = true;
        salyInvoices = new();
        if (selectedCustomerId == null) return;
        var yr = salyYear.ToString();
        await using var db = DbFactory.CreateDbContext();
        salyInvoices = await db.Orders
            .Where(o => o.CustomerId == selectedCustomerId.Value && o.OrderYear == yr)
            .OrderBy(o => o.OrderId)
            .Select(o => new SalyInvoice(o.OrderId, o.OrderDate, o.OrderTotal, o.NetTotal))
            .ToListAsync();
    }

    private async Task ApplySaly(int invoiceId)
    {
        var yearStr = year.ToString();
        await using var db = DbFactory.CreateDbContext();

        // Map last year's invoice lines to this year's products via UniversalItemNumber.
        var mapped = await db.OrderDetails
            .Where(od => od.OrderId == invoiceId)
            .Join(db.Products, od => od.ProductId, prev => prev.ProductID,
                (od, prev) => new { od.Quantity, prev.UniversalItemNumber })
            .Where(x => x.UniversalItemNumber != null)
            .Join(db.Products.Where(cur => cur.ProductYear == yearStr),
                x => x.UniversalItemNumber, cur => cur.UniversalItemNumber,
                (x, cur) => new { cur.ProductID, cur.ItemNumber, cur.ProductName, x.Quantity })
            .ToListAsync();

        var grouped = mapped
            .GroupBy(m => new { m.ProductID, m.ItemNumber, m.ProductName })
            .Select(g => new { g.Key.ProductID, g.Key.ItemNumber, g.Key.ProductName, Qty = (int)Math.Round(g.Sum(x => x.Quantity ?? 0)) })
            .Where(g => g.Qty > 0)
            .ToList();

        int added = 0;
        foreach (var g in grouped)
        {
            var existing = lines.FirstOrDefault(l => l.ProductId == g.ProductID);
            if (existing != null) existing.Qty = g.Qty;
            else lines.Add(new NewLine { ProductId = g.ProductID, ItemNumber = g.ItemNumber, ProductName = g.ProductName, Qty = g.Qty });
            added++;
        }
        salyMsg = $"Loaded {added} item(s) from invoice #{invoiceId} ({salyYear}), mapped to {year} products.";
    }

    // ---- Excel import (flexible column mapping) ----
    private object?[][] importRows = Array.Empty<object?[]>();
    private int importCols = 0;
    private int skipRows = 1;
    private int matchCol = 0;
    private int qtyCol = 1;
    private string matchBy = "ItemNumber";
    private string importMsg = "";

    private record ProdRow(int ProductId, int? ItemNumber, string? Uin, string? Name);

    private static string ColLabel(int c) => c < 26 ? ((char)('A' + c)).ToString() : $"Col{c + 1}";

    private static string CellText(object?[] r, int c)
        => (c >= 0 && c < r.Length && r[c] != null && r[c] != DBNull.Value) ? r[c]!.ToString() ?? "" : "";

    private static object? CellRaw(object?[] r, int c)
        => (c >= 0 && c < r.Length && r[c] != DBNull.Value) ? r[c] : null;

    private string SampleValue(int c)
    {
        foreach (var r in importRows.Skip(Math.Max(0, skipRows)))
        {
            var v = CellText(r, c);
            if (!string.IsNullOrWhiteSpace(v)) return v.Length <= 16 ? v : v[..16] + "…";
        }
        return "";
    }

    private async Task OnImportFile(InputFileChangeEventArgs e)
    {
        importMsg = "";
        importRows = Array.Empty<object?[]>();
        importCols = 0;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;
            using var reader = ExcelReaderFactory.CreateReader(ms);
            var ds = reader.AsDataSet(new ExcelDataSetConfiguration
            {
                ConfigureDataTable = _ => new ExcelDataTableConfiguration { UseHeaderRow = false }
            });
            if (ds.Tables.Count == 0) { importMsg = "No sheets found in the file."; return; }
            var table = ds.Tables[0];
            importCols = table.Columns.Count;
            importRows = table.Rows.Cast<DataRow>().Select(r => (object?[])r.ItemArray).ToArray();
            if (importCols > 1) qtyCol = 1;
        }
        catch (Exception ex)
        {
            importMsg = $"Could not read the file: {ex.Message}";
        }
    }

    private async Task ApplyImport()
    {
        if (importCols == 0 || selectedCustomerId == null) return;
        var yearStr = year.ToString();

        List<ProdRow> products;
        await using (var db = DbFactory.CreateDbContext())
        {
            products = await db.Products
                .Where(p => p.ProductYear == yearStr)
                .Select(p => new ProdRow(p.ProductID, p.ItemNumber, p.UniversalItemNumber, p.ProductName))
                .ToListAsync();
        }

        var lookup = new Dictionary<string, ProdRow>();
        foreach (var p in products)
        {
            var key = ProdKey(p);
            if (!string.IsNullOrEmpty(key) && !lookup.ContainsKey(key)) lookup[key] = p;
        }

        int matched = 0, unmatched = 0;
        for (int i = Math.Max(0, skipRows); i < importRows.Length; i++)
        {
            var key = NormalizeKey(CellRaw(importRows[i], matchCol));
            if (string.IsNullOrEmpty(key)) continue;
            var qty = ParseQty(CellRaw(importRows[i], qtyCol));
            if (qty <= 0) continue;

            if (lookup.TryGetValue(key, out var prod))
            {
                var existing = lines.FirstOrDefault(l => l.ProductId == prod.ProductId);
                if (existing != null) existing.Qty = qty;
                else lines.Add(new NewLine { ProductId = prod.ProductId, ItemNumber = prod.ItemNumber, ProductName = prod.Name, Qty = qty });
                matched++;
            }
            else unmatched++;
        }

        importMsg = $"{matched} item(s) imported; {unmatched} row(s) didn't match a {year} product.";
    }

    private string? ProdKey(ProdRow p) => matchBy switch
    {
        "ItemNumber" => p.ItemNumber?.ToString(),
        "UniversalItemNumber" => p.Uin?.Trim().ToUpperInvariant(),
        _ => p.Name?.Trim().ToUpperInvariant()
    };

    private string? NormalizeKey(object? o)
    {
        if (o == null) return null;
        if (matchBy == "ItemNumber")
        {
            if (o is double d && d == Math.Floor(d)) return ((long)d).ToString();
            var s = o.ToString()?.Trim();
            if (s != null && s.EndsWith(".0")) s = s[..^2];
            return string.IsNullOrEmpty(s) ? null : s;
        }
        return o.ToString()?.Trim().ToUpperInvariant();
    }

    private static int ParseQty(object? o)
    {
        if (o == null) return 0;
        if (o is double d) return (int)Math.Round(d);
        return int.TryParse(o.ToString(), out var v) ? v : 0;
    }

    private async Task Save()
    {
        if (selectedCustomerId == null) { isError = true; statusMessage = "Select a customer."; return; }
        var orderLines = lines.Where(l => l.Qty > 0).ToList();
        if (!orderLines.Any()) { isError = true; statusMessage = "Add at least one item with a quantity."; return; }

        isSaving = true;
        try
        {
            var order = new OrdersTaken
            {
                CustomerID = selectedCustomerId.Value,
                LastName = selectedCustomerName,
                TypeOrder = typeOrder,
                PickUpTime = pickupDate,
                TimeTaken = DateTime.Now,
                Status = "Taken",
                OrderYear = year.ToString(),
                OrdersTakenDetails = orderLines.Select(l => new OrdersTakenDetails
                {
                    ProductID = l.ProductId,
                    QuantityOrdered = l.Qty,
                    Notes = l.Notes
                }).ToList()
            };

            await using var db = DbFactory.CreateDbContext();
            db.OrdersTakens.Add(order);
            await db.SaveChangesAsync();

            // Hand off to the editor for the order just created.
            Nav.NavigateTo($"/orders/{order.OrdersTakenID}");
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"Error saving order: {ex.Message}";
            isSaving = false;
        }
    }
}
