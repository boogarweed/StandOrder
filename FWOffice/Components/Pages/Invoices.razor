@page "/invoices"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using FWOffice.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject WorkingYearState YearState
@implements IDisposable

<PageTitle>Invoices</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Invoices — @year</h1>
    <button class="btn btn-success" @onclick='() => Nav.NavigateTo("invoices/new")'>+ New Invoice</button>
</div>

<div class="row g-2 mb-3 align-items-end">
    <div class="col">
        <label class="form-label">Find (ID or customer)</label>
        <input class="form-control" placeholder="Type to filter..." @bind="textFilter" @bind:event="oninput" />
    </div>
</div>

@if (CustomerIdFilter != null)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center py-2">
        <span>Showing invoices for <strong>@CustomerFilterName</strong>.</span>
        <a class="btn btn-sm btn-outline-secondary" href="invoices">Clear filter</a>
    </div>
}

@if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <p class="text-muted">@Filtered.Count invoice(s)</p>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Full Name</th>
                    <th>Order Date</th>
                    <th>Pricesheet</th>
                    <th class="text-end">Order Total</th>
                    <th class="text-end">Net Total</th>
                    <th>Last Update</th>
                </tr>
            </thead>
            <tbody>
                @if (!Filtered.Any())
                {
                    <tr><td colspan="7" class="text-muted">No invoices match.</td></tr>
                }
                @foreach (var o in Filtered)
                {
                    <tr style="cursor: pointer;" @onclick="() => Open(o.OrderId)">
                        <td>@o.OrderId</td>
                        <td>@o.FullName</td>
                        <td>@o.OrderDate.ToString("MM/dd/yyyy")</td>
                        <td>@o.PriceSheetName</td>
                        <td class="text-end">@o.OrderTotal?.ToString("C")</td>
                        <td class="text-end">@o.NetTotal?.ToString("C")</td>
                        <td>@o.LastUpdateDate?.ToString("MM/dd/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "customerId")]
    public int? CustomerIdFilter { get; set; }

    private int year;
    private string textFilter = "";
    private bool loading = true;
    private List<InvoiceRow> invoices = new();

    private record InvoiceRow(int OrderId, int CustomerId, string? FullName, DateTime OrderDate, string? PriceSheetName,
        decimal? OrderTotal, decimal? NetTotal, DateTime? LastUpdateDate);

    private List<InvoiceRow> Filtered =>
        invoices.Where(o => (CustomerIdFilter == null || o.CustomerId == CustomerIdFilter)
                         && (string.IsNullOrWhiteSpace(textFilter)
                             || o.OrderId.ToString().Contains(textFilter)
                             || (o.FullName ?? "").Contains(textFilter, StringComparison.OrdinalIgnoreCase)))
                .ToList();

    // Name shown in the "filtered by customer" banner (from any of that customer's invoices).
    private string CustomerFilterName =>
        invoices.FirstOrDefault(i => i.CustomerId == CustomerIdFilter)?.FullName ?? "this customer";

    private void Open(int id) => Nav.NavigateTo($"invoices/{id}");

    protected override async Task OnInitializedAsync()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
        await LoadInvoices();
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        await LoadInvoices();
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    private async Task LoadInvoices()
    {
        loading = true;
        var yearStr = year.ToString();
        await using var db = DbFactory.CreateDbContext();
        invoices = await db.Orders
            .Where(o => o.OrderYear == yearStr)
            .OrderByDescending(o => o.OrderId)
            .Join(db.Customers, o => o.CustomerId, c => c.CustomerID, (o, c) => new { o, c.FullName })
            .Select(x => new InvoiceRow(
                x.o.OrderId,
                x.o.CustomerId,
                x.FullName,
                x.o.OrderDate,
                db.PriceSheets.Where(ps => ps.PriceSheetNumber == x.o.PriceSheetNumber).Select(ps => ps.PriceSheetName).FirstOrDefault(),
                x.o.OrderTotal,
                x.o.NetTotal,
                x.o.LastUpdateDate))
            .ToListAsync();
        loading = false;
    }
}
