@page "/invoices"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using FWOffice.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject WorkingYearState YearState
@implements IDisposable

<PageTitle>Invoices</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Invoices — @year</h1>
    <button class="btn btn-success" @onclick='() => Nav.NavigateTo("invoices/new")'>+ New Invoice</button>
</div>

<div class="row g-2 mb-2 align-items-end">
    <div class="col-md-6">
        <label class="form-label">Find (ID or customer)</label>
        <input class="form-control" placeholder="Type to filter..." @bind="textFilter" @bind:event="oninput" />
    </div>

    <!-- Product picker -->
    <div class="col-md-6 position-relative">
        <label class="form-label">Product (bought by customer)</label>
        @if (pickedProductId == null)
        {
            <input class="form-control" placeholder="Item # or name..." value="@prodSearch" @oninput="OnProdSearch" />
            @if (prodResults.Any())
            {
                <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 280px; overflow-y: auto;">
                    @foreach (var p in prodResults)
                    {
                        <button type="button" class="list-group-item list-group-item-action" @onclick="() => PickProduct(p)">
                            <span class="fw-bold">@p.ItemNumber</span> — @p.ProductName
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <div class="input-group">
                <input class="form-control" value="@pickedProductLabel" readonly />
                <button class="btn btn-outline-secondary" title="Clear product" @onclick="ClearPickedProduct">×</button>
            </div>
        }
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <p class="text-muted">@Filtered.Count invoice(s)@(pickedProductId == null ? "" : $" — item {pickedProductLabel}")</p>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Full Name</th>
                    <th>Order Date</th>
                    <th>Pricesheet</th>
                    <th class="text-end">Order Total</th>
                    <th class="text-end">Net Total</th>
                    <th>Last Update</th>
                </tr>
            </thead>
            <tbody>
                @if (!Filtered.Any())
                {
                    <tr><td colspan="7" class="text-muted">No invoices match.</td></tr>
                }
                @foreach (var o in Filtered)
                {
                    <tr style="cursor: pointer;" @onclick="() => Open(o.OrderId)">
                        <td>@o.OrderId</td>
                        <td>@o.FullName</td>
                        <td>@o.OrderDate.ToString("MM/dd/yyyy")</td>
                        <td>@o.PriceSheetName</td>
                        <td class="text-end">@o.OrderTotal?.ToString("C")</td>
                        <td class="text-end">@o.NetTotal?.ToString("C")</td>
                        <td>@o.LastUpdateDate?.ToString("MM/dd/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "customerId")]
    public int? CustomerIdFilter { get; set; }

    private int year;
    private string textFilter = "";
    private bool loading = true;
    private List<InvoiceRow> invoices = new();

    // Product picker
    private string prodSearch = "";
    private List<ProductPick> prodResults = new();
    private int? pickedProductId;
    private string pickedProductLabel = "";
    private HashSet<int> productOrderIds = new();   // OrderIds (this year) that contain the picked product

    private record InvoiceRow(int OrderId, int CustomerId, string? FullName, DateTime OrderDate, string? PriceSheetName,
        decimal? OrderTotal, decimal? NetTotal, DateTime? LastUpdateDate);
    private record ProductPick(int ProductId, int? ItemNumber, string ProductName);

    private List<InvoiceRow> Filtered =>
        invoices.Where(o => (pickedProductId == null || productOrderIds.Contains(o.OrderId))
                         && (string.IsNullOrWhiteSpace(textFilter)
                             || o.OrderId.ToString().Contains(textFilter)
                             || (o.FullName ?? "").Contains(textFilter, StringComparison.OrdinalIgnoreCase)))
                .ToList();

    private void Open(int id) => Nav.NavigateTo($"invoices/{id}");

    protected override async Task OnInitializedAsync()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
        await LoadInvoices();

        // Arriving via ?customerId= (the "This Customer's Invoices" link) pre-fills the existing
        // Find box with the customer's name, so there's just the one customer filter.
        if (CustomerIdFilter != null)
        {
            var name = invoices.FirstOrDefault(i => i.CustomerId == CustomerIdFilter)?.FullName;
            if (string.IsNullOrEmpty(name))
            {
                await using var db = DbFactory.CreateDbContext();
                name = await db.Customers.Where(c => c.CustomerID == CustomerIdFilter)
                    .Select(c => c.FullName).FirstOrDefaultAsync();
            }
            if (!string.IsNullOrEmpty(name)) textFilter = name;
        }
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        await LoadInvoices();
        if (pickedProductId != null) await LoadProductOrderIds();   // product's orders are year-scoped
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    private async Task LoadInvoices()
    {
        loading = true;
        var yearStr = year.ToString();
        await using var db = DbFactory.CreateDbContext();
        invoices = await db.Orders
            .Where(o => o.OrderYear == yearStr)
            .OrderByDescending(o => o.OrderId)
            .Join(db.Customers, o => o.CustomerId, c => c.CustomerID, (o, c) => new { o, c.FullName })
            .Select(x => new InvoiceRow(
                x.o.OrderId,
                x.o.CustomerId,
                x.FullName,
                x.o.OrderDate,
                db.PriceSheets.Where(ps => ps.PriceSheetNumber == x.o.PriceSheetNumber).Select(ps => ps.PriceSheetName).FirstOrDefault(),
                x.o.OrderTotal,
                x.o.NetTotal,
                x.o.LastUpdateDate))
            .ToListAsync();
        loading = false;
    }

    // ---- Product picker ----
    private async Task OnProdSearch(ChangeEventArgs e)
    {
        prodSearch = e.Value?.ToString() ?? "";
        var term = prodSearch.Trim();
        if (string.IsNullOrWhiteSpace(term)) { prodResults = new(); return; }
        var yr = year.ToString();
        int? termNum = int.TryParse(term, out var n) ? n : (int?)null;
        await using var db = DbFactory.CreateDbContext();
        prodResults = await db.Products
            .Where(p => p.ProductYear == yr && p.ProductName != null
                        && (p.ProductName.Contains(term) || (termNum != null && p.ItemNumber == termNum)))
            .OrderBy(p => p.ItemNumber).Take(25)
            .Select(p => new ProductPick(p.ProductID, p.ItemNumber, p.ProductName!))
            .ToListAsync();
    }

    private async Task PickProduct(ProductPick p)
    {
        pickedProductId = p.ProductId;
        pickedProductLabel = $"{p.ItemNumber} — {p.ProductName}";
        prodResults = new();
        prodSearch = "";
        await LoadProductOrderIds();
    }

    private void ClearPickedProduct()
    {
        pickedProductId = null;
        pickedProductLabel = "";
        prodResults = new();
        prodSearch = "";
        productOrderIds = new();
    }

    // OrderIds for the working year whose [Order Details] include the picked product.
    private async Task LoadProductOrderIds()
    {
        productOrderIds = new();
        if (pickedProductId == null) return;
        var yr = year.ToString();
        await using var db = DbFactory.CreateDbContext();
        var ids = await (
            from od in db.OrderDetails
            join o in db.Orders on od.OrderId equals o.OrderId
            where o.OrderYear == yr && od.ProductId == pickedProductId
            select od.OrderId).Distinct().ToListAsync();
        productOrderIds = ids.ToHashSet();
    }
}
