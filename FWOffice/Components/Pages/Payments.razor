@page "/payments"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using FWOffice.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject WorkingYearState YearState
@implements IDisposable

<PageTitle>Payments</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Payments — @year</h1>
    <button class="btn btn-success" @onclick='() => Nav.NavigateTo("/payments/new")'>+ New Payment</button>
</div>

<div class="d-flex gap-3 align-items-end mb-2 flex-wrap">
    <div style="max-width: 24rem;">
        <label class="form-label">Find (ID, customer, check #)</label>
        <input class="form-control" placeholder="Type to filter..." @bind="filter" @bind:event="oninput" />
    </div>
    <div class="text-muted ms-auto mb-2">@Filtered.Count payment(s)</div>
</div>

@if (loading)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr><th>Payment ID</th><th>Full Name</th><th class="text-end">Amount</th><th>Date</th><th>Type</th><th>Check #</th></tr>
            </thead>
            <tbody>
                @if (!Filtered.Any())
                {
                    <tr><td colspan="6" class="text-muted">No payments match.</td></tr>
                }
                @foreach (var p in Filtered)
                {
                    <tr style="cursor: pointer;" @onclick="() => Open(p.PaymentId)">
                        <td>@p.PaymentId</td>
                        <td>@p.FullName</td>
                        <td class="text-end">@p.Amount?.ToString("C")</td>
                        <td>@p.PayDate?.ToString("MM/dd/yyyy")</td>
                        <td>@p.PayType</td>
                        <td>@p.CheckNum</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int year;
    private bool loading = true;
    private string filter = "";
    private List<Row> rows = new();

    private record Row(int PaymentId, string? FullName, decimal? Amount, DateOnly? PayDate, string? PayType, string? CheckNum);

    private List<Row> Filtered =>
        rows.Where(p => string.IsNullOrWhiteSpace(filter)
                || p.PaymentId.ToString().Contains(filter)
                || (p.FullName ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase)
                || (p.CheckNum ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void Open(int id) => Nav.NavigateTo($"/payments/{id}");

    protected override async Task OnInitializedAsync()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
        await Load();
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        await Load();
        StateHasChanged();
    });

    private async Task Load()
    {
        loading = true;
        var yr = year.ToString();
        await using var db = DbFactory.CreateDbContext();
        rows = await db.Payments
            .Where(p => p.PayYear == yr)
            .OrderByDescending(p => p.PaymentId)
            .Join(db.Customers, p => p.CustomerId, c => c.CustomerID,
                (p, c) => new Row(p.PaymentId, c.FullName, p.PayAmount, p.PayDate, p.PayType, p.CheckNum))
            .ToListAsync();
        loading = false;
    }

    public void Dispose() => YearState.OnChange -= HandleYearChange;
}
