@page "/reports/endofseason"
@rendermode InteractiveServer
@using System.Text
@using FWOffice.Services
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject WorkingYearState YearState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>End of Season Reports</PageTitle>

<h1 class="mb-3 d-print-none">End of Season Reports</h1>

@* Report chooser — panels 3-across; nothing runs until clicked. *@
<div class="row g-3 mb-4 d-print-none">
    @foreach (var r in Reports)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 @(activeReport == r.Key ? "border-primary" : "")">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@r.Title</h5>
                    <p class="card-text text-muted small flex-grow-1">@r.Description</p>
                    <button class="btn @(activeReport == r.Key ? "btn-primary" : "btn-outline-primary") align-self-start"
                            @onclick="() => RunReportPanel(r.Key)">Run report</button>
                </div>
            </div>
        </div>
    }
</div>

@if (activeReport == "paytype")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Payment Type Summary</div>
        <div class="card-body">
            @if (!payAuthed)
            {
                <div style="max-width: 22rem;">
                    <label class="form-label">Enter password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" @bind="payPassword" @bind:event="oninput"
                               @onkeydown="PayKeyDown" />
                        <button class="btn btn-primary" @onclick="SubmitPayPassword">Unlock</button>
                    </div>
                    @if (!string.IsNullOrEmpty(payPwError))
                    {
                        <div class="text-danger small mt-1">@payPwError</div>
                    }
                </div>
            }
            else if (payLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(payError))
            {
                <div class="alert alert-danger">Error building the report: @payError</div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                    <div class="text-muted">Total payments collected by type, per year.</div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportPayExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                </div>

                <h4 class="mt-1">Payment Type Summary</h4>
                <table class="table table-sm table-striped" style="max-width: 40rem;">
                    <thead>
                        <tr><th class="text-end">Total</th><th>Type</th><th>Year</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in payRows)
                        {
                            <tr>
                                <td class="text-end">@Cur(r.Total)</td>
                                <td>@r.Type</td>
                                <td>@r.Year</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

else if (activeReport == "nopermit")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Orders Without Permits</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">
                    @year orders whose customer has an expired permit or none on file@(noPermitRows.Any() ? $" ({noPermitRows.Count})" : "").
                </div>
                @if (noPermitRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportNoPermitExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Customer Orders Without Current Permits <span class="text-muted fs-6">(@year)</span></h4>
            @if (noPermitLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(noPermitError))
            {
                <div class="alert alert-danger">Error building the report: @noPermitError</div>
            }
            else if (!noPermitRows.Any())
            {
                <p class="text-muted">No orders without current permits for @year.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Order Number</th><th>Customer</th><th>Business</th><th>Order Date</th>
                                <th class="text-end">Order Total</th><th>Permit Expiration Date</th>
                                <th>STS Number</th><th>Permit Number</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in noPermitRows)
                            {
                                <tr>
                                    <td>@r.OrderID</td>
                                    <td>@r.Customer</td>
                                    <td>@r.Business</td>
                                    <td>@(r.OrderDate?.ToString("MM/dd/yyyy"))</td>
                                    <td class="text-end">@Cur(r.OrderTotal)</td>
                                    <td>@(r.ExpirationDate?.ToString("MM/dd/yyyy"))</td>
                                    <td>@r.StsNumber</td>
                                    <td>@r.PermitNumber</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

else if (activeReport == "nototal")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Orders Without Totals</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">
                    @year orders with a missing or zero total@(noTotalRows.Any() ? $" ({noTotalRows.Count})" : "").
                </div>
                @if (noTotalRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportNoTotalExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Orders Without Totals <span class="text-muted fs-6">(@year)</span></h4>
            @if (noTotalLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(noTotalError))
            {
                <div class="alert alert-danger">Error building the report: @noTotalError</div>
            }
            else if (!noTotalRows.Any())
            {
                <p class="text-muted">No orders without totals for @year.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Order Number</th><th>Customer</th>
                                <th class="text-end">Stand Charges</th><th class="text-end">License Charges</th>
                                <th class="text-end">Insurance Charges</th><th class="text-end">Misc Charges</th>
                                <th class="text-end">Net Total</th><th class="text-end">Order Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in noTotalRows)
                            {
                                <tr>
                                    <td>@r.OrderID</td>
                                    <td>@r.Customer</td>
                                    <td class="text-end">@Cur(r.StandCharges)</td>
                                    <td class="text-end">@Cur(r.LicenseCharges)</td>
                                    <td class="text-end">@Cur(r.InsuranceCharges)</td>
                                    <td class="text-end">@Cur(r.MiscCharges)</td>
                                    <td class="text-end">@Cur(r.NetTotal)</td>
                                    <td class="text-end">@Cur(r.OrderTotal)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

else if (activeReport == "whattoorder")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">What to Order</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">
                    Total sold vs. stock for @year@(whatRows.Any() ? $" ({whatRows.Count} products)" : "").
                </div>
                @if (whatRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportWhatExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Total Sold versus Qty in Stock <span class="text-muted fs-6">(@year)</span></h4>
            @if (whatLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(whatError))
            {
                <div class="alert alert-danger">Error building the report: @whatError</div>
            }
            else if (!whatRows.Any())
            {
                <p class="text-muted">No sold products for @year.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Product ID</th><th>Item Number</th><th>Product Name</th>
                                <th class="text-end">Total Sold</th><th class="text-end">Qty In Stock</th>
                                <th class="text-end">Cases to Order</th>
                                <th class="text-end" title="Ordered minus pulled (in cases) from warehouse-pull orders where a pulled quantity was recorded — how much demand we couldn't fill.">Unmet Demand</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in whatRows)
                            {
                                <tr>
                                    <td>@r.ProductID</td>
                                    <td>@r.ItemNumber</td>
                                    <td>@r.ProductName</td>
                                    <td class="text-end">@Num(r.TotalSold)</td>
                                    <td class="text-end">@Num(r.QtyInStock)</td>
                                    <td class="text-end @(r.CasesToOrder > 0 ? "fw-semibold" : "text-muted")">@Num(r.CasesToOrder)</td>
                                    <td class="text-end @(r.UnmetDemand > 0 ? "fw-semibold text-danger" : "text-muted")">@Num(r.UnmetDemand)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

else if (activeReport == "sts")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">STS Report</div>
        <div class="card-body">
            <div class="d-flex align-items-end gap-2 mb-3 d-print-none" style="max-width: 26rem;">
                <div>
                    <label class="form-label mb-1">Report year</label>
                    <input type="number" class="form-control" @bind="stsYear" style="max-width: 8rem;" />
                </div>
                <button class="btn btn-primary" @onclick="LoadSts" disabled="@stsLoading">Run report</button>
                @if (stsRan && stsRows.Any())
                {
                    <button class="btn btn-outline-secondary" @onclick="ExportStsExcel">Open in Excel</button>
                    <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                }
            </div>

            @if (stsLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(stsError))
            {
                <div class="alert alert-danger">Error building the report: @stsError</div>
            }
            else if (stsRan)
            {
                <h4 class="mt-1">Customer Orders &amp; Payments with Permits <span class="text-muted fs-6">(@stsYear)</span></h4>
                @if (!stsRows.Any())
                {
                    <p class="text-muted">No orders &amp; payments with permits for @stsYear.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Customer ID</th><th>Customer</th><th>Location</th><th>Account ID</th>
                                    <th>Permit Number</th><th>Expiration Date</th>
                                    <th class="text-end">Order Total</th><th class="text-end">Pay Amount</th><th>Year</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in stsRows)
                                {
                                    <tr>
                                        <td>@r.CustomerID</td>
                                        <td>@r.FullName</td>
                                        <td>@r.Location</td>
                                        <td>@r.AccountID</td>
                                        <td>@r.PermitNumber</td>
                                        <td>@(r.ExpirationDate?.ToString("MM/dd/yyyy"))</td>
                                        <td class="text-end">@Cur(r.OrderTotal)</td>
                                        <td class="text-end">@Cur(r.PayAmount)</td>
                                        <td>@r.Year</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

@* Additional end-of-season reports will be added below as further panels/cards. *@

@code {
    private int year;
    private string? activeReport;

    protected override void OnInitialized()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        if (activeReport == "nopermit") await LoadNoPermit();
        else if (activeReport == "nototal") await LoadNoTotal();
        else if (activeReport == "whattoorder") await LoadWhatToOrder();
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    private record ReportDef(string Key, string Title, string Description);
    private static readonly ReportDef[] Reports = new[]
    {
        new ReportDef("paytype", "Payment Type Summary",
            "Password-protected. Total payments collected by type (Cash / Check / Credit Card), per year."),
        new ReportDef("nopermit", "Orders Without Permits",
            "Working-year orders whose customer has an expired permit or no permit on file."),
        new ReportDef("nototal", "Orders Without Totals",
            "Working-year orders with a missing or zero order total (excludes the showroom account)."),
        new ReportDef("whattoorder", "What to Order",
            "Total cases sold vs. quantity in stock per product, with cases to order, for the working year."),
        new ReportDef("sts", "STS Report",
            "Customer orders & payments with permits for a chosen year (duplicate permit rows keep the order/pay total only once)."),
    };

    // Payment Type Summary (password-gated)
    private bool payAuthed;
    private string payPassword = "";
    private string payPwError = "";
    private bool payLoading;
    private string payError = "";
    private List<PayRow> payRows = new();
    private record PayRow(decimal Total, string? Type, string? Year);

    // Orders Without Permits (working-year scoped)
    private bool noPermitLoading;
    private string noPermitError = "";
    private List<NoPermitRow> noPermitRows = new();
    private record NoPermitRow(int OrderID, string? Customer, string? Business, DateTime? OrderDate,
        decimal OrderTotal, DateTime? ExpirationDate, string? StsNumber, string? PermitNumber);

    // Orders Without Totals (working-year scoped)
    private bool noTotalLoading;
    private string noTotalError = "";
    private List<NoTotalRow> noTotalRows = new();
    private record NoTotalRow(int OrderID, string? Customer, decimal StandCharges, decimal LicenseCharges,
        decimal InsuranceCharges, decimal MiscCharges, decimal NetTotal, decimal OrderTotal);

    // What to Order (working-year scoped)
    private bool whatLoading;
    private string whatError = "";
    private List<WhatRow> whatRows = new();
    private record WhatRow(int ProductID, int ItemNumber, string? ProductName,
        decimal TotalSold, decimal QtyInStock, decimal CasesToOrder, decimal UnmetDemand);

    // STS Report (user picks the report year)
    private int stsYear = DateTime.Today.Year;
    private bool stsLoading;
    private bool stsRan;
    private string stsError = "";
    private List<StsRow> stsRows = new();
    private record StsRow(int CustomerID, string? FullName, string? Location, string? AccountID,
        string? PermitNumber, DateTime? ExpirationDate, decimal OrderTotal, decimal PayAmount, string? Year);

    private async Task RunReportPanel(string key)
    {
        activeReport = key;
        if (key == "paytype")
        {
            payAuthed = false; payPassword = ""; payPwError = ""; payError = ""; payRows = new();
        }
        else if (key == "nopermit")
        {
            await LoadNoPermit();
        }
        else if (key == "nototal")
        {
            await LoadNoTotal();
        }
        else if (key == "whattoorder")
        {
            await LoadWhatToOrder();
        }
        else if (key == "sts")
        {
            stsYear = year; stsRan = false; stsError = ""; stsRows = new();
        }
    }

    // ---- Orders Without Permits ------------------------------------------

    private async Task LoadNoPermit()
    {
        noPermitLoading = true;
        noPermitError = "";
        var list = new List<NoPermitRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                "SELECT OrderID, FullName, BusinessName, OrderDate, OrderTotal, ExpirationDate, " +
                "SalesAccountID, SalesPermitNumber FROM vCustOrderPermits " +
                "WHERE (ExpirationDate < OrderDate OR ExpirationDate IS NULL) AND OrderYear = @yr " +
                "ORDER BY FullName", con);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                list.Add(new NoPermitRow(
                    rdr["OrderID"] is DBNull ? 0 : Convert.ToInt32(rdr["OrderID"]),
                    rdr["FullName"] as string,
                    rdr["BusinessName"] as string,
                    rdr["OrderDate"] as DateTime?,
                    rdr["OrderTotal"] is DBNull ? 0m : Convert.ToDecimal(rdr["OrderTotal"]),
                    rdr["ExpirationDate"] as DateTime?,
                    rdr["SalesAccountID"] as string,
                    rdr["SalesPermitNumber"] as string));
            }
            noPermitRows = list;
        }
        catch (Exception ex) { noPermitError = ex.Message; }
        finally { noPermitLoading = false; }
    }

    private async Task ExportNoPermitExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Order Number,Customer,Business,Order Date,Order Total,Permit Expiration Date,STS Number,Permit Number");
        foreach (var r in noPermitRows)
            sb.AppendLine($"{r.OrderID},{Csv(r.Customer)},{Csv(r.Business)},{r.OrderDate:MM/dd/yyyy}," +
                $"{r.OrderTotal:0.00},{r.ExpirationDate:MM/dd/yyyy},{Csv(r.StsNumber)},{Csv(r.PermitNumber)}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"OrdersWithoutPermits_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- Orders Without Totals -------------------------------------------

    private async Task LoadNoTotal()
    {
        noTotalLoading = true;
        noTotalError = "";
        var list = new List<NoTotalRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                "SELECT OrderID, FullName, StandCharges, LicenseCharges, InsuranceCharges, MiscCharges, " +
                "NetTotal, OrderTotal FROM vCustomerOrders " +
                "WHERE OrderYear = @yr AND (OrderTotal IS NULL OR OrderTotal = 0) " +
                "AND CustomerID <> 845 ORDER BY FullName", con);   // 845 = showroom, ignored
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            decimal D(object o) => o is DBNull ? 0m : Convert.ToDecimal(o);
            while (await rdr.ReadAsync())
            {
                list.Add(new NoTotalRow(
                    rdr["OrderID"] is DBNull ? 0 : Convert.ToInt32(rdr["OrderID"]),
                    rdr["FullName"] as string,
                    D(rdr["StandCharges"]), D(rdr["LicenseCharges"]), D(rdr["InsuranceCharges"]),
                    D(rdr["MiscCharges"]), D(rdr["NetTotal"]), D(rdr["OrderTotal"])));
            }
            noTotalRows = list;
        }
        catch (Exception ex) { noTotalError = ex.Message; }
        finally { noTotalLoading = false; }
    }

    private async Task ExportNoTotalExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Order Number,Customer,Stand Charges,License Charges,Insurance Charges,Misc Charges,Net Total,Order Total");
        foreach (var r in noTotalRows)
            sb.AppendLine($"{r.OrderID},{Csv(r.Customer)},{r.StandCharges:0.00},{r.LicenseCharges:0.00}," +
                $"{r.InsuranceCharges:0.00},{r.MiscCharges:0.00},{r.NetTotal:0.00},{r.OrderTotal:0.00}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"OrdersWithoutTotals_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- What to Order ---------------------------------------------------

    private async Task LoadWhatToOrder()
    {
        whatLoading = true;
        whatError = "";
        var list = new List<WhatRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            // Unmet Demand: ordered-minus-pulled from warehouse-pull orders (OrdersTaken) for the
            // year, counting only lines where a pulled quantity was recorded (QuantityPulled not
            // null), regardless of status. OrdersTaken quantities are in packs, so we normalize to
            // cases via PacksPerCase to match the rest of the report. The pre-aggregated subquery is
            // one row per product, so joining it does not inflate SUM(v.OrderQty).
            // Stock comes from the live QuantityInStock (individual items, trigger-maintained);
            // the old QtyInStock column is deprecated/stale. Normalize items to cases via
            // ItemsPerPack * PacksPerCase to match the rest of the report (Total Sold is cases).
            await using var cmd = new SqlCommand(
                "SELECT p.ProductID, p.ItemNumber, p.ProductName, " +
                "ROUND(SUM(v.OrderQty), 2) AS TotalSold, " +
                "ROUND(p.QuantityInStock * 1.0 / NULLIF(p.ItemsPerPack * p.PacksPerCase, 0), 2) AS QtyInStock, " +
                "ROUND((ROUND(SUM(v.OrderQty), 2) - COALESCE(p.QuantityInStock * 1.0 / NULLIF(p.ItemsPerPack * p.PacksPerCase, 0), 0)), 2) AS CasesToOrder, " +
                "ROUND(COALESCE(MAX(otd.UnmetPacks), 0) * 1.0 / NULLIF(p.PacksPerCase, 0), 2) AS UnmetDemand " +
                "FROM vNormalizedQty v " +
                "JOIN Products p ON v.ProductID = p.ProductID " +
                "JOIN Orders o ON v.OrderID = o.OrderID " +
                "LEFT JOIN ( " +
                "  SELECT d.ProductID, SUM(d.QuantityOrdered - d.QuantityPulled) AS UnmetPacks " +
                "  FROM OrdersTakenDetails d " +
                "  JOIN OrdersTaken t ON d.OrdersTakenID = t.OrdersTakenID " +
                "  WHERE t.OrderYear = @yr AND d.QuantityPulled IS NOT NULL " +
                "  GROUP BY d.ProductID " +
                ") otd ON otd.ProductID = p.ProductID " +
                "WHERE p.ProductYear = @yr " +
                "GROUP BY p.ProductID, p.ItemNumber, p.ProductName, p.QuantityInStock, p.ItemsPerPack, p.PacksPerCase " +
                "ORDER BY p.ItemNumber", con);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            decimal D(object o) => o is DBNull ? 0m : Convert.ToDecimal(o);
            while (await rdr.ReadAsync())
            {
                list.Add(new WhatRow(
                    rdr["ProductID"] is DBNull ? 0 : Convert.ToInt32(rdr["ProductID"]),
                    rdr["ItemNumber"] is DBNull ? 0 : Convert.ToInt32(rdr["ItemNumber"]),
                    rdr["ProductName"] as string,
                    D(rdr["TotalSold"]), D(rdr["QtyInStock"]), D(rdr["CasesToOrder"]), D(rdr["UnmetDemand"])));
            }
            whatRows = list;
        }
        catch (Exception ex) { whatError = ex.Message; }
        finally { whatLoading = false; }
    }

    private async Task ExportWhatExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Product ID,Item Number,Product Name,Total Sold,Qty In Stock,Cases to Order,Unmet Demand");
        foreach (var r in whatRows)
            sb.AppendLine($"{r.ProductID},{r.ItemNumber},{Csv(r.ProductName)}," +
                $"{r.TotalSold:0.##},{r.QtyInStock:0.##},{r.CasesToOrder:0.##},{r.UnmetDemand:0.##}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"WhatToOrder_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- STS Report ------------------------------------------------------

    // Runs the legacy batch verbatim (temp table + cursor). The cursor zeroes the
    // OrderTotal/PayAmount of each row whose OrderTotal repeats the previous row's,
    // so a customer with several permits keeps the total only once. This is
    // order-dependent, so we run the same SQL rather than reimplement it in C#.
    // FORMAT() (compat 110) is dropped; currency is formatted in C#.
    private const string StsSql = @"
DECLARE @ordertotal money, @prev_ordertotal money;
DECLARE @temp_table TABLE (CustomerID int, FullName nvarchar(82), Location nvarchar(311), SalesAccountID nvarchar(50), SalesPermitNumber nvarchar(50), ExpirationDate date, OrderTotal money, PayAmount money, OrderYear nchar(4));
INSERT INTO @temp_table
SELECT vCustOrderTotalByYear.CustomerID, Customers.FullName,
       CONCAT(BusinessAddress, ', ', BusinessCity, ', ', BusinessState) AS Location,
       CustomerPermits.SalesAccountID, CustomerPermits.SalesPermitNumber, CustomerPermits.ExpirationDate,
       vCustOrderTotalByYear.OrderTotal, vCustPayTotalByYear.PayAmount, vCustOrderTotalByYear.OrderYear
FROM vCustOrderTotalByYear
  INNER JOIN vCustPayTotalByYear ON vCustOrderTotalByYear.CustomerID = vCustPayTotalByYear.CustomerID
  INNER JOIN Customers ON vCustOrderTotalByYear.CustomerID = Customers.CustomerID
  INNER JOIN CustomerPermits ON vCustOrderTotalByYear.CustomerID = CustomerPermits.CustomerID
WHERE OrderYear = @year AND PayYear = @year;
DECLARE mycursor CURSOR FOR SELECT OrderTotal FROM @temp_table;
OPEN mycursor;
FETCH NEXT FROM mycursor INTO @ordertotal;
WHILE @@FETCH_STATUS = 0
BEGIN
  IF (@ordertotal = @prev_ordertotal)
    UPDATE @temp_table SET OrderTotal = 0, PayAmount = 0 WHERE CURRENT OF mycursor;
  SET @prev_ordertotal = @ordertotal;
  FETCH NEXT FROM mycursor INTO @ordertotal;
END
CLOSE mycursor;
DEALLOCATE mycursor;
SELECT CustomerID, FullName, Location, SalesAccountID, SalesPermitNumber, ExpirationDate,
       OrderTotal, PayAmount, OrderYear
FROM @temp_table
WHERE CustomerID <> 399;";

    private async Task LoadSts()
    {
        stsLoading = true;
        stsError = "";
        stsRan = true;
        var list = new List<StsRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(StsSql, con);
            cmd.Parameters.AddWithValue("@year", stsYear.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            decimal D(object o) => o is DBNull ? 0m : Convert.ToDecimal(o);
            while (await rdr.ReadAsync())
            {
                list.Add(new StsRow(
                    rdr["CustomerID"] is DBNull ? 0 : Convert.ToInt32(rdr["CustomerID"]),
                    rdr["FullName"] as string,
                    rdr["Location"] as string,
                    rdr["SalesAccountID"] as string,
                    rdr["SalesPermitNumber"] as string,
                    rdr["ExpirationDate"] as DateTime?,
                    D(rdr["OrderTotal"]), D(rdr["PayAmount"]),
                    (rdr["OrderYear"] as string)?.Trim()));
            }
            stsRows = list;
        }
        catch (Exception ex) { stsError = ex.Message; }
        finally { stsLoading = false; }
    }

    private async Task ExportStsExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Customer ID,Customer,Location,Account ID,Permit Number,Expiration Date,Order Total,Pay Amount,Year");
        foreach (var r in stsRows)
            sb.AppendLine($"{r.CustomerID},{Csv(r.FullName)},{Csv(r.Location)},{Csv(r.AccountID)}," +
                $"{Csv(r.PermitNumber)},{r.ExpirationDate:MM/dd/yyyy},{r.OrderTotal:0.00},{r.PayAmount:0.00},{Csv(r.Year)}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"STSReport_{stsYear}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- Payment Type Summary --------------------------------------------

    private async Task PayKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitPayPassword();
    }

    private async Task SubmitPayPassword()
    {
        if (payPassword == "glitter")
        {
            payPwError = "";
            payAuthed = true;
            await LoadPaymentTypeSummary();
        }
        else
        {
            payPwError = "Wrong password.";
        }
    }

    private async Task LoadPaymentTypeSummary()
    {
        payLoading = true;
        payError = "";
        var list = new List<PayRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                "SELECT Expr1 AS Total, PayType AS Type, PayYear AS Year " +
                "FROM dbo.vPayByType ORDER BY PayYear DESC", con);
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var total = rdr["Total"] is DBNull ? 0m : Convert.ToDecimal(rdr["Total"]);
                list.Add(new PayRow(total, rdr["Type"] as string, (rdr["Year"] as string)?.Trim()));
            }
            payRows = list;
        }
        catch (Exception ex) { payError = ex.Message; }
        finally { payLoading = false; }
    }

    private async Task ExportPayExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Total,Type,Year");
        foreach (var r in payRows)
            sb.AppendLine($"{r.Total:0.00},{Csv(r.Type)},{Csv(r.Year)}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", "PaymentTypeSummary.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private static string Cur(decimal d) =>
        d.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-US"));

    private static string Num(decimal d) =>
        d.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string Csv(string? value)
    {
        var v = value ?? "";
        return (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            ? "\"" + v.Replace("\"", "\"\"") + "\""
            : v;
    }
}
