@page "/trucks/{TruckID:int}/report"
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

@* Printable truck report (replaces the legacy frmSeeTrucks). Auto-prints. *@

<PageTitle>Truck @TruckID — Report</PageTitle>

@if (notFound)
{
    <p>Truck @TruckID was not found.</p>
}
else
{
    <div class="pull-sheet">
        <div class="d-print-none mb-3">
            <button class="btn btn-primary" onclick="window.print()">Print</button>
        </div>

        <h2>Truck #@TruckID</h2>
        <p>
            <strong>Received From:</strong> @supplierName &nbsp;|&nbsp;
            <strong>Date Received:</strong> @receivedDate?.ToString("MM/dd/yyyy")
        </p>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Item #</th>
                    <th>Product Name</th>
                    <th>Quantity Received</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in items)
                {
                    <tr>
                        <td>@i.ItemNumber</td>
                        <td>@i.ProductName</td>
                        <td>@i.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script>
        window.addEventListener('load', () => window.print());
    </script>
}

@code {
    [Parameter] public int TruckID { get; set; }

    private bool notFound = false;
    private string supplierName = "";
    private DateTime? receivedDate;
    private List<Row> items = new();

    private record Row(int? ItemNumber, string? ProductName, int Quantity);

    protected override async Task OnInitializedAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        var header = await db.Trucks
            .Where(t => t.TruckID == TruckID)
            .Select(t => new { t.ReceivedDate, t.Supplier.SupplierName })
            .FirstOrDefaultAsync();

        if (header == null) { notFound = true; return; }
        supplierName = header.SupplierName ?? "";
        receivedDate = header.ReceivedDate;

        var raw = await db.TruckProducts
            .Where(tp => tp.TruckID == TruckID)
            .Join(db.Products, tp => tp.ProductID, p => p.ProductID,
                (tp, p) => new { p.ItemNumber, p.ProductName, tp.QuantityReceived })
            .OrderBy(x => x.ItemNumber)
            .ToListAsync();
        items = raw.Select(x => new Row(x.ItemNumber, x.ProductName, x.QuantityReceived)).ToList();
    }
}
