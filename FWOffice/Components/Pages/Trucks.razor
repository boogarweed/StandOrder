@page "/trucks"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using FWOffice.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject WorkingYearState YearState
@implements IDisposable

<PageTitle>Trucks</PageTitle>

<h1 class="mb-3">Trucks — @year season</h1>

<div class="d-flex gap-3 align-items-end mb-2 flex-wrap">
    <div style="max-width: 24rem;">
        <label class="form-label">Filter</label>
        <input class="form-control" placeholder="Supplier or truck #..." @bind="filter" @bind:event="oninput" />
    </div>
    <div class="text-muted ms-auto mb-2">@Filtered.Count truck(s)</div>
</div>

@if (loading)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr><th>Truck #</th><th>Supplier</th><th>Received</th><th class="text-end">Products</th></tr>
            </thead>
            <tbody>
                @if (!Filtered.Any())
                {
                    <tr><td colspan="4" class="text-muted">No trucks.</td></tr>
                }
                @foreach (var t in Filtered)
                {
                    <tr style="cursor: pointer;" @onclick="() => Open(t.TruckId)">
                        <td>@t.TruckId</td>
                        <td>@t.SupplierName</td>
                        <td>@t.ReceivedDate.ToString("MM/dd/yyyy")</td>
                        <td class="text-end">@t.ProductCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int year;
    private bool loading = true;
    private string filter = "";
    private List<Row> trucks = new();

    private record Row(int TruckId, string? SupplierName, DateTime ReceivedDate, int ProductCount);

    private List<Row> Filtered =>
        trucks.Where(t => string.IsNullOrWhiteSpace(filter)
                || t.TruckId.ToString().Contains(filter)
                || (t.SupplierName ?? "").Contains(filter, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void Open(int id) => Nav.NavigateTo($"trucks/{id}");

    protected override async Task OnInitializedAsync()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
        await Load();
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        await Load();
        StateHasChanged();
    });

    private async Task Load()
    {
        loading = true;
        // The season's trucks: received after July 31 of the prior year (legacy gstrLastYear-07-31).
        var cutoff = new DateTime(year - 1, 7, 31);
        await using var db = DbFactory.CreateDbContext();
        trucks = await db.Trucks
            .Where(t => t.ReceivedDate > cutoff)
            .OrderByDescending(t => t.ReceivedDate)
            .Select(t => new Row(t.TruckID, t.Supplier.SupplierName, t.ReceivedDate, t.TruckProducts.Count()))
            .ToListAsync();
        loading = false;
    }

    public void Dispose() => YearState.OnChange -= HandleYearChange;
}
