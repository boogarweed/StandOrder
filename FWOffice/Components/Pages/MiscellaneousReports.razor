@page "/reports/miscellaneous"
@rendermode InteractiveServer
@using System.Text
@using FWOffice.Services
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject WorkingYearState YearState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Miscellaneous Reports</PageTitle>

<h1 class="mb-3 d-print-none">Miscellaneous Reports</h1>

@* Report chooser — panels 3-across; nothing runs until clicked. *@
<div class="row g-3 mb-4 d-print-none">
    @foreach (var r in Reports)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 @(activeReport == r.Key ? "border-primary" : "")">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@r.Title</h5>
                    <p class="card-text text-muted small flex-grow-1">@r.Description</p>
                    <button class="btn @(activeReport == r.Key ? "btn-primary" : "btn-outline-primary") align-self-start"
                            @onclick="() => RunReportPanel(r.Key)">Run report</button>
                </div>
            </div>
        </div>
    }
</div>

@if (activeReport == "cashprice")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Cash Price</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">
                    Cash price sheet for @year@(cashRows.Any() ? $" ({cashRows.Count} items)" : "").
                </div>
                @if (cashRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportCashExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Cash Price Sheet <span class="text-muted fs-6">(@year)</span></h4>
            @if (cashLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(cashError))
            {
                <div class="alert alert-danger">Error building the report: @cashError</div>
            }
            else if (!cashRows.Any())
            {
                <p class="text-muted">No cash prices for @year.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Item Number</th><th>Product Name</th>
                                <th class="text-end">Your Cost</th><th>Packing</th>
                                <th style="min-width:5rem;">Qty</th><th style="min-width:7rem;">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in cashRows)
                            {
                                <tr>
                                    <td>@r.ItemNumber</td>
                                    <td>@r.ProductName</td>
                                    <td class="text-end">@r.YourCost.ToString("0.00")</td>
                                    <td>@r.Packing</td>
                                    <td>&nbsp;</td>
                                    <td>&nbsp;</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

else if (activeReport == "inventory")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Inventory</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">
                    Current inventory count sheet for @year@(invRows.Any() ? $" ({invRows.Count} items)" : "").
                </div>
                @if (invRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportInventoryExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Current Inventory <span class="text-muted fs-6">(@year)</span></h4>
            @if (invLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(invError))
            {
                <div class="alert alert-danger">Error building the report: @invError</div>
            }
            else if (!invRows.Any())
            {
                <p class="text-muted">No inventory for @year.</p>
            }
            else
            {
                @foreach (var g in invRows.GroupBy(r => r.Category))
                {
                    <h5 class="mt-3">@(string.IsNullOrWhiteSpace(g.Key) ? "(no category)" : g.Key)</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Item Number</th><th>Product Name</th>
                                    <th class="text-end">Qty</th>
                                    <th style="min-width:6rem;">Actual Case</th><th style="min-width:6rem;">Actual Pack</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in g)
                                {
                                    <tr>
                                        <td>@r.ItemNumber</td>
                                        <td>@r.ProductName</td>
                                        <td class="text-end">@r.Qty.ToString("0.##")</td>
                                        <td>&nbsp;</td>
                                        <td>&nbsp;</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

else if (activeReport == "labels")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Price Labels</div>
        <div class="card-body">
            <div class="d-flex align-items-end gap-2 mb-3 d-print-none" style="max-width: 32rem;">
                <div>
                    <label class="form-label mb-1">Price sheet</label>
                    <select class="form-select" @bind="labelSheet" style="max-width: 14rem;">
                        <option value="Showroom Retail">Showroom Retail</option>
                        <option value="Catalog Retail">Catalog Retail</option>
                    </select>
                </div>
                <button class="btn btn-primary" @onclick="LoadLabels" disabled="@labelBuilding">Build labels</button>
            </div>

            @if (labelBuilding)
            {
                <p><em>Building…</em></p>
            }
            else if (!string.IsNullOrEmpty(labelError))
            {
                <div class="alert alert-danger">Error building the labels: @labelError</div>
            }
            else if (!string.IsNullOrEmpty(labelHtml))
            {
                <p class="text-muted small d-print-none">
                    @labelCount labels for @year (@labelSheet). Use the Print button inside the sheet to print on label stock.
                </p>
                <iframe srcdoc="@labelHtml" style="width:100%; height:80vh; border:1px solid #dee2e6;"></iframe>
            }
        </div>
    </div>
}

else if (activeReport == "recall")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Recall</div>
        <div class="card-body">
            <div class="d-flex align-items-end gap-2 mb-3 d-print-none" style="max-width: 30rem;">
                <div>
                    <label class="form-label mb-1">Item number</label>
                    <input type="number" class="form-control" @bind="recallItem" @onkeydown="RecallKeyDown"
                           style="max-width: 10rem;" />
                </div>
                <button class="btn btn-primary" @onclick="LoadRecall" disabled="@(recallLoading || recallItem is null)">Run report</button>
                @if (recallRan && recallRows.Any())
                {
                    <button class="btn btn-outline-secondary" @onclick="ExportRecallExcel">Open in Excel</button>
                    <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                }
            </div>

            @if (recallLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!string.IsNullOrEmpty(recallError))
            {
                <div class="alert alert-danger">Error building the report: @recallError</div>
            }
            else if (recallRan)
            {
                <h4 class="mt-1">Recall Report <span class="text-muted fs-6">(item @recallItem, @year)</span></h4>
                @if (!recallRows.Any())
                {
                    <p class="text-muted">No customers ordered item @recallItem in @year.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Customer</th><th>Customer ID</th><th>Item Number</th><th>Item Name</th>
                                    <th class="text-end">Quantity</th><th>Case?</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in recallRows)
                                {
                                    <tr>
                                        <td>@r.Customer</td>
                                        <td>@r.CustomerID</td>
                                        <td>@r.ItemNumber</td>
                                        <td>@r.ProductName</td>
                                        <td class="text-end">@r.Quantity.ToString("0.##")</td>
                                        <td>@r.CaseQty</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

@* Additional miscellaneous reports will be added below as further panels/cards. *@

@code {
    private int year;
    private string? activeReport;

    private record ReportDef(string Key, string Title, string Description);
    private static readonly ReportDef[] Reports = new[]
    {
        new ReportDef("cashprice", "Cash Price",
            "Printable cash price sheet for the working year: item, product, your cost, and packing, with blank Qty / Total Cost columns."),
        new ReportDef("inventory", "Inventory",
            "Physical count sheet for the working year, grouped by category, with blank Actual Case / Actual Pack columns."),
        new ReportDef("labels", "Price Labels",
            "Printable price-label sheet (18 per page) for the working year, priced from the chosen price sheet."),
        new ReportDef("recall", "Recall",
            "Every customer who ordered a given item number in the working year, with quantity ordered."),
    };

    protected override void OnInitialized()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        if (activeReport == "cashprice") await LoadCashPrice();
        else if (activeReport == "inventory") await LoadInventory();
        else if (activeReport == "recall" && recallRan && recallItem is not null) await LoadRecall();
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    // Cash Price (working-year scoped)
    private bool cashLoading;
    private string cashError = "";
    private List<CashRow> cashRows = new();
    private record CashRow(int ItemNumber, string? ProductName, decimal YourCost, string? Packing);

    // Inventory (working-year scoped, grouped by category)
    private bool invLoading;
    private string invError = "";
    private List<InvRow> invRows = new();
    private record InvRow(string? Category, int ItemNumber, string? ProductName, decimal Qty);

    // Price Labels (working-year scoped; choose a price sheet)
    private string labelSheet = "Showroom Retail";
    private bool labelBuilding;
    private string labelError = "";
    private string labelHtml = "";
    private int labelCount;
    private record LabelRow(int ItemNumber, string? ProductName, decimal EachPrice, string? PackName, decimal PackPrice);

    // Recall (working-year scoped; find who ordered an item number)
    private int? recallItem;
    private bool recallLoading;
    private bool recallRan;
    private string recallError = "";
    private List<RecallRow> recallRows = new();
    private record RecallRow(string? Customer, int CustomerID, int ItemNumber, string? ProductName,
        decimal Quantity, string? CaseQty);

    private async Task RunReportPanel(string key)
    {
        activeReport = key;
        if (key == "cashprice")
        {
            await LoadCashPrice();
        }
        else if (key == "inventory")
        {
            await LoadInventory();
        }
        else if (key == "labels")
        {
            labelHtml = ""; labelError = ""; labelCount = 0;
        }
        else if (key == "recall")
        {
            recallItem = null; recallRan = false; recallError = ""; recallRows = new();
        }
    }

    // ---- Cash Price ------------------------------------------------------

    private async Task LoadCashPrice()
    {
        cashLoading = true;
        cashError = "";
        var list = new List<CashRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                "SELECT ItemNumber, ProductName, CAST(ROUND(UnitPrice2, 2) AS decimal(10,2)) AS YourCost, " +
                "CONCAT('per ', PackName) AS Packing FROM vCashPrice " +
                "WHERE ProductYear = @yr ORDER BY ItemNumber", con);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                list.Add(new CashRow(
                    rdr["ItemNumber"] is DBNull ? 0 : Convert.ToInt32(rdr["ItemNumber"]),
                    rdr["ProductName"] as string,
                    rdr["YourCost"] is DBNull ? 0m : Convert.ToDecimal(rdr["YourCost"]),
                    rdr["Packing"] as string));
            }
            cashRows = list;
        }
        catch (Exception ex) { cashError = ex.Message; }
        finally { cashLoading = false; }
    }

    private async Task ExportCashExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Item Number,Product Name,Your Cost,Packing,Qty,Total Cost");
        foreach (var r in cashRows)
            sb.AppendLine($"{r.ItemNumber},{Csv(r.ProductName)},{r.YourCost:0.00},{Csv(r.Packing)},,");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"CashPriceSheet_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- Inventory -------------------------------------------------------

    private async Task LoadInventory()
    {
        invLoading = true;
        invError = "";
        var list = new List<InvRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            // Legacy orders by ItemNumber and groups by category in the report writer;
            // we sort Category then ItemNumber so each category section stays item-ordered.
            // Stock is the live QuantityInStock (items) normalized to cases; the old QtyInStock
            // column is deprecated/stale.
            await using var cmd = new SqlCommand(
                "SELECT Category, ItemNumber, ProductName, " +
                "ISNULL(ROUND(QuantityInStock * 1.0 / NULLIF(ItemsPerPack * PacksPerCase, 0), 2), 0.00) AS Qty " +
                "FROM Products WHERE ProductYear = @yr ORDER BY Category, ItemNumber", con);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                list.Add(new InvRow(
                    rdr["Category"] as string,
                    rdr["ItemNumber"] is DBNull ? 0 : Convert.ToInt32(rdr["ItemNumber"]),
                    rdr["ProductName"] as string,
                    rdr["Qty"] is DBNull ? 0m : Convert.ToDecimal(rdr["Qty"])));
            }
            invRows = list;
        }
        catch (Exception ex) { invError = ex.Message; }
        finally { invLoading = false; }
    }

    private async Task ExportInventoryExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Category,Item Number,Product Name,Qty,Actual Case,Actual Pack");
        foreach (var r in invRows)
            sb.AppendLine($"{Csv(r.Category)},{r.ItemNumber},{Csv(r.ProductName)},{r.Qty:0.##},,");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"Inventory_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    // ---- Price Labels ----------------------------------------------------

    private async Task LoadLabels()
    {
        labelBuilding = true;
        labelError = "";
        labelHtml = "";
        var rows = new List<LabelRow>();
        try
        {
            // Price columns depend on the chosen sheet (matches legacy btnPrintPriceLabels).
            // NULLIF guards the Catalog divide (legacy did not, so a 0-pack item would throw).
            string priceCols = labelSheet == "Catalog Retail"
                ? "((UnitPrice4 / NULLIF(ItemsPerPack,0)) * 2) AS EachPrice, UnitPrice4 AS PackPrice"
                : "UnitPrice12 AS EachPrice, (UnitPrice12 * ItemsPerPack) AS PackPrice";

            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                $"SELECT ItemNumber, ProductName, {priceCols}, PackName FROM Products " +
                "WHERE ProductYear = @yr AND ItemNumber <= 3000 ORDER BY ItemNumber", con);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            decimal D(object o) => o is DBNull ? 0m : Convert.ToDecimal(o);
            while (await rdr.ReadAsync())
            {
                rows.Add(new LabelRow(
                    rdr["ItemNumber"] is DBNull ? 0 : Convert.ToInt32(rdr["ItemNumber"]),
                    rdr["ProductName"] as string,
                    D(rdr["EachPrice"]), rdr["PackName"] as string, D(rdr["PackPrice"])));
            }
            labelCount = rows.Count;
            labelHtml = BuildLabelHtml(rows);
        }
        catch (Exception ex) { labelError = ex.Message; }
        finally { labelBuilding = false; }
    }

    private static string BuildLabelHtml(List<LabelRow> rows)
    {
        string Enc(string? s) => System.Net.WebUtility.HtmlEncode(s ?? "");
        string Cur(decimal d) => d.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-US"));

        var sb = new StringBuilder();
        sb.Append("<!DOCTYPE html><html><head><meta charset='utf-8'><style>");
        sb.Append("body{font-family:Arial,Helvetica,sans-serif;margin:.25in;}");
        sb.Append(".toolbar{margin-bottom:.15in;}");
        sb.Append(".sheet{width:100%;}");
        sb.Append(".label{display:inline-block;box-sizing:border-box;width:2.6in;height:1.6in;border:1px solid #bbb;");
        sb.Append("padding:.12in;margin:0;vertical-align:top;overflow:hidden;}");
        sb.Append(".sublabel{font-size:11pt;line-height:1.3;height:100%;}");
        sb.Append(".topleft{float:left;font-size:8pt;color:#888;}");
        sb.Append(".topright{float:right;font-weight:bold;}");
        sb.Append(".btmleft{float:left;font-weight:bold;} .btmright{float:right;font-weight:bold;}");
        sb.Append(".page-break{page-break-before:always;break-before:page;width:100%;height:0;overflow:hidden;}");
        sb.Append("@media print{.toolbar{display:none;} .label{border:1px solid #ddd;}}");
        sb.Append("</style></head><body>");
        sb.Append("<div class='toolbar'><a href='#' onclick='window.print();return false;'>Print</a></div>");
        sb.Append("<div class='sheet'>");

        int recordCount = 0;
        foreach (var r in rows)
        {
            recordCount++;
            if (recordCount == 19)   // 18 labels per page, then break (matches legacy)
            {
                recordCount = 1;
                sb.Append("<div class='page-break'></div>");
            }

            var name = r.ProductName ?? "";
            if (name.Length > 25) name = name.Substring(0, 25);
            name = name.Replace("/JUNEBUG", " JUNEBUG");

            sb.Append("<div class='label'><div class='sublabel'>");
            sb.Append("<span class='topleft'>barcode</span>");
            sb.Append($"<span class='topright'>ITEM # {r.ItemNumber}</span><br>");
            sb.Append($"{Enc(name)}<br>");
            sb.Append($"<span class='btmleft'>{Cur(r.EachPrice)}ea</span>");
            sb.Append($"<span class='btmright'>{Cur(r.PackPrice)}{Enc(r.PackName)}</span>");
            sb.Append("</div></div>");
        }

        sb.Append("</div></body></html>");
        return sb.ToString();
    }

    // ---- Recall ----------------------------------------------------------

    private async Task RecallKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && recallItem is not null) await LoadRecall();
    }

    private async Task LoadRecall()
    {
        if (recallItem is null) return;
        recallLoading = true;
        recallError = "";
        recallRan = true;
        var list = new List<RecallRow>();
        try
        {
            await using var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection"));
            await using var cmd = new SqlCommand(
                "SELECT FullName, CustomerID, ItemNumber, ProductName, Quantity, CaseQty FROM vrecall " +
                "WHERE ItemNumber = @item AND ProductYear = @yr", con);
            cmd.Parameters.AddWithValue("@item", recallItem.Value);
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                list.Add(new RecallRow(
                    rdr["FullName"] as string,
                    rdr["CustomerID"] is DBNull ? 0 : Convert.ToInt32(rdr["CustomerID"]),
                    rdr["ItemNumber"] is DBNull ? 0 : Convert.ToInt32(rdr["ItemNumber"]),
                    rdr["ProductName"] as string,
                    rdr["Quantity"] is DBNull ? 0m : Convert.ToDecimal(rdr["Quantity"]),
                    (rdr["CaseQty"] as string)?.Trim()));
            }
            recallRows = list;
        }
        catch (Exception ex) { recallError = ex.Message; }
        finally { recallLoading = false; }
    }

    private async Task ExportRecallExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Customer,Customer ID,Item Number,Item Name,Quantity,Case?");
        foreach (var r in recallRows)
            sb.AppendLine($"{Csv(r.Customer)},{r.CustomerID},{r.ItemNumber},{Csv(r.ProductName)},{r.Quantity:0.##},{Csv(r.CaseQty)}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"Recall_{recallItem}_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private static string Csv(string? value)
    {
        var v = value ?? "";
        return (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            ? "\"" + v.Replace("\"", "\"\"") + "\""
            : v;
    }
}
