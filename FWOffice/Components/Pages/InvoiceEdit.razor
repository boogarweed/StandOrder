@page "/invoices/new"
@page "/invoices/{OrderId:int}"
@rendermode InteractiveServer
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using FWOffice.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject InvoiceService Invoices
@inject NavigationManager Nav
@inject WorkingYearState YearState
@inject IJSRuntime JS

<PageTitle>@(OrderId == null ? "New Invoice" : $"Invoice {OrderId}")</PageTitle>

<style>
    .inv-grid-head, .inv-grid-row { display: grid; grid-template-columns: 90px 1fr 50px 90px 110px 110px; gap: .4rem; align-items: center; }
    .inv-grid-head { font-weight: 600; padding: .35rem .5rem; border: 1px solid #dee2e6; border-bottom: 2px solid #adb5bd; background: #f8f9fa; }
    .inv-grid-scroll { border: 1px solid #dee2e6; border-top: 0; }
    .inv-grid-row { padding: .1rem .5rem; border-bottom: 1px solid #f0f0f0; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@(OrderId == null ? "New Invoice" : $"Invoice #{OrderId}")</h1>
    @if (OrderId != null)
    {
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="invoices/@OrderId/document" target="_blank">View / Print Invoice</a>
            <button class="btn btn-outline-danger" @onclick="Delete" disabled="@isBusy">Delete Invoice</button>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">@statusMessage</div>
}

<div class="row g-3 mb-3">
    <!-- Customer -->
    <div class="col-md-5 position-relative">
        <label class="form-label">Customer <span class="text-danger">*</span></label>
        @if (selectedCustomerId == null)
        {
            <input class="form-control" placeholder="Search customer..." value="@custSearchText" @oninput="OnCustSearch" />
            @if (custResults.Any())
            {
                <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 300px; overflow-y: auto;">
                    @foreach (var c in custResults)
                    {
                        <button type="button" class="list-group-item list-group-item-action" @onclick="() => SelectCustomer(c)">
                            <strong>@c.FullName</strong>
                            @if (!string.IsNullOrWhiteSpace(c.BusinessName)) { <span class="text-muted"> — @c.BusinessName</span> }
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <div class="input-group">
                <input class="form-control" value="@customerName" readonly />
                @if (OrderId == null)
                {
                    <button class="btn btn-outline-secondary" @onclick="ClearCustomer">Change</button>
                }
            </div>
            @if (permitWarning)
            {
                <small class="text-danger">No current sales-tax permit on file — sales tax applies.</small>
            }
        }
    </div>

    <!-- Pricesheet -->
    <div class="col-md-4">
        <label class="form-label">Pricesheet <span class="text-danger">*</span></label>
        <select class="form-select" @bind="selectedPricesheet" @bind:after="OnPricesheetChanged" disabled="@(selectedCustomerId == null)">
            <option value="">-- Select --</option>
            @foreach (var ps in pricesheets)
            {
                <option value="@ps.PriceSheetNumber">@ps.PriceSheetName (@(ps.CaseQty?.Trim() == "Y" ? "Case" : "Broken"))</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Year</label>
        <input class="form-control" @bind="orderYear" readonly />
    </div>
</div>

@if (selectedCustomerId != null && !string.IsNullOrEmpty(selectedPricesheet))
{
    <!-- Import -->
    <div class="d-flex justify-content-end mb-2">
        <button class="btn btn-outline-primary" @onclick="ToggleImport">Import Pulled Order</button>
    </div>

    @if (showImport)
    {
        <div class="border rounded p-2 mb-2">
            <div class="fw-semibold mb-1">Pulled / Return / Loaded orders for @customerName (@YearState.Year)</div>
            @if (!importList.Any())
            {
                <div class="text-muted">No matching orders to import.</div>
            }
            else
            {
                <div class="table-responsive" style="max-height: 220px; overflow: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>Taken</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var o in importList)
                            {
                                <tr>
                                    <td>@o.Id</td>
                                    <td>@o.TypeOrder</td>
                                    <td>@o.Status</td>
                                    <td>@o.TimeTaken.ToString("MM/dd/yyyy")</td>
                                    <td><button class="btn btn-sm btn-outline-primary" @onclick="() => Import(o.Id)">Import</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <!-- Item grid -->
    <div class="d-flex gap-3 align-items-end mb-2 flex-wrap">
        <div style="max-width: 22rem;">
            <label class="form-label">Filter items</label>
            <input class="form-control" placeholder="Item # or name..." @bind="gridFilter" @bind:event="oninput" @bind:after="RecomputeFilter" />
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="onlyEntered" @bind="onlyEntered" @bind:after="RecomputeFilter" />
            <label class="form-check-label" for="onlyEntered">Only items with a quantity</label>
        </div>
        <div class="text-muted ms-auto mb-2">@EnteredCount item(s) on invoice</div>
    </div>

    <div class="inv-grid-head">
        <div>Item #</div><div>Product</div><div>Net</div><div>Qty</div><div>Unit Price</div><div class="text-end">Extended</div>
    </div>
    <div class="inv-grid-scroll" style="height: 460px; overflow-y: auto;">
        @if (gridLoading)
        {
            <div class="p-3 text-muted">Loading items…</div>
        }
        else if (!filteredRows.Any())
        {
            <div class="p-3 text-muted">No items match.</div>
        }
        else
        {
            <Virtualize Items="filteredRows" Context="row" ItemSize="44">
                <div class="inv-grid-row">
                    <div>@row.ItemNumber</div>
                    <div>@row.ProductName</div>
                    <div>@(row.NetItem ? "Y" : "")</div>
                    <div><input type="number" min="0" step="1" class="form-control form-control-sm" @bind="row.Qty" @bind:after="ComputeTotals" /></div>
                    <div><input type="number" step="0.01" class="form-control form-control-sm" @bind="row.UnitPrice" @bind:after="ComputeTotals" /></div>
                    <div class="text-end">@row.Extended.ToString("C")</div>
                </div>
            </Virtualize>
        }
    </div>

    <!-- Charges + totals -->
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Charges</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-2">
                            <label class="form-label">Misc</label>
                            <input type="number" step="0.01" class="form-control" @bind="misc" @bind:after="ComputeTotals" />
                        </div>
                        <div class="col-6 mb-2">
                            <label class="form-label">Misc reason</label>
                            <input class="form-control" @bind="chargeText" />
                        </div>
                        <div class="col-6 mb-2">
                            <label class="form-label">License</label>
                            <input type="number" step="0.01" class="form-control" @bind="license" @bind:after="ComputeTotals" />
                        </div>
                        <div class="col-6 mb-2">
                            <label class="form-label">Insurance</label>
                            <input type="number" step="0.01" class="form-control" @bind="insurance" @bind:after="ComputeTotals" />
                        </div>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="chkTax" @bind="salesTaxEnabled" @bind:after="ComputeTotals" />
                        <label class="form-check-label" for="chkTax">Charge sales tax (@taxRate.ToString("P3"))</label>
                    </div>
                    <div class="mt-2">
                        <label class="form-label">Customer notes</label>
                        <textarea class="form-control" rows="2" @bind="customerNotes"></textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Totals</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-7">Net items</dt><dd class="col-5 text-end">@netItemsTotal.ToString("C")</dd>
                        <dt class="col-7">Items subtotal</dt><dd class="col-5 text-end">@itemsTotal.ToString("C")</dd>
                        <dt class="col-7">Misc</dt><dd class="col-5 text-end">@misc.ToString("C")</dd>
                        <dt class="col-7">Sales tax</dt><dd class="col-5 text-end">@salesTax.ToString("C")</dd>
                        <dt class="col-7">License</dt><dd class="col-5 text-end">@license.ToString("C")</dd>
                        <dt class="col-7">Insurance</dt><dd class="col-5 text-end">@insurance.ToString("C")</dd>
                        <dt class="col-7 fs-5">Total</dt><dd class="col-5 text-end fs-5">@total.ToString("C")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <button class="btn btn-success" @onclick="Post" disabled="@isBusy">@(isBusy ? "Saving..." : "Post Invoice")</button>
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/invoices")' disabled="@isBusy">Cancel</button>
    </div>
}

@code {
    [Parameter] public int? OrderId { get; set; }

    private List<PriceSheet> pricesheets = new();
    private decimal taxRate = 0m;

    private int? selectedCustomerId;
    private string customerName = "";
    private string customerNotes = "";
    private string custSearchText = "";
    private List<Customer> custResults = new();

    private string selectedPricesheet = "";
    private string orderYear = DateTime.Today.Year.ToString();

    // Full priced grid
    private List<InvRow> gridRows = new();
    private List<InvRow> filteredRows = new();
    private string gridFilter = "";
    private bool onlyEntered = false;
    private bool gridLoading = false;
    private HashSet<int> originalLineProductIds = new();

    private decimal license, insurance, misc;
    private string chargeText = "";
    private bool salesTaxEnabled;
    private decimal salesTax;
    private bool permitWarning;

    private decimal netItemsTotal, itemsTotal, total;

    private int? importedOtid;

    private bool showImport;
    private List<ImportOption> importList = new();

    private string statusMessage = "";
    private bool isError;
    private bool isBusy;

    private int EnteredCount => gridRows.Count(r => r.Qty > 0);

    private record ImportOption(int Id, string? Status, string? TypeOrder, DateTime TimeTaken);

    private class InvRow
    {
        public int ProductId { get; set; }
        public int? ItemNumber { get; set; }
        public string? ProductName { get; set; }
        public bool NetItem { get; set; }
        public int Qty { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal Extended => Math.Round(Qty * UnitPrice, 2, MidpointRounding.AwayFromZero);
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        pricesheets = await db.PriceSheets.OrderBy(p => p.PriceSheetName).ToListAsync();
        taxRate = (await db.OurCompanyInfos.Select(o => o.SalesTaxRate).FirstOrDefaultAsync()) ?? 0m;
        orderYear = YearState.Year.ToString();
    }

    private int? loadedOrderId;

    protected override async Task OnParametersSetAsync()
    {
        if (OrderId != null && OrderId != loadedOrderId)
        {
            loadedOrderId = OrderId;
            await LoadExisting();
        }
    }

    private async Task LoadExisting()
    {
        await using var db = DbFactory.CreateDbContext();
        var header = await db.Orders.AsNoTracking().FirstOrDefaultAsync(o => o.OrderId == OrderId);
        if (header == null) { isError = true; statusMessage = "Invoice not found."; return; }

        selectedCustomerId = header.CustomerId;
        selectedPricesheet = header.PriceSheetNumber ?? "";
        orderYear = header.OrderYear ?? DateTime.Today.Year.ToString();
        license = header.LicenseCharges ?? 0m;
        insurance = header.InsuranceCharges ?? 0m;
        misc = header.MiscCharges ?? 0m;
        chargeText = header.ChargeText ?? "";
        salesTax = header.SalesTax ?? 0m;
        salesTaxEnabled = (header.SalesTax ?? 0m) > 0m;

        var cust = await db.Customers.AsNoTracking().FirstOrDefaultAsync(c => c.CustomerID == selectedCustomerId);
        customerName = cust?.FullName ?? "";
        customerNotes = cust?.Notes ?? "";

        await LoadCatalog();

        // Apply the saved [Order Details] (qty + saved unit price) onto the grid rows.
        var detail = await db.OrderDetails.AsNoTracking()
            .Where(d => d.OrderId == OrderId)
            .Select(d => new { d.ProductId, d.Quantity, d.UnitPrice })
            .ToListAsync();
        originalLineProductIds = new();
        foreach (var d in detail)
        {
            var row = gridRows.FirstOrDefault(r => r.ProductId == d.ProductId);
            if (row != null)
            {
                row.Qty = (int)Math.Round(d.Quantity ?? 0);
                row.UnitPrice = Math.Round(d.UnitPrice ?? 0m, 2);
                originalLineProductIds.Add(d.ProductId);
            }
        }
        RecomputeFilter();
        ComputeTotals();
    }

    private async Task OnCustSearch(ChangeEventArgs e)
    {
        custSearchText = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(custSearchText)) { custResults = new(); return; }
        var term = custSearchText.Trim();
        await using var db = DbFactory.CreateDbContext();
        custResults = await db.Customers
            .Where(c => (c.FullName != null && c.FullName.Contains(term))
                     || (c.LastName != null && c.LastName.Contains(term))
                     || (c.BusinessName != null && c.BusinessName.Contains(term)))
            .OrderBy(c => c.LastName).Take(25).AsNoTracking().ToListAsync();
    }

    private async Task SelectCustomer(Customer c)
    {
        selectedCustomerId = c.CustomerID;
        customerName = c.FullName ?? "";
        custResults = new();
        custSearchText = "";

        await using var db = DbFactory.CreateDbContext();
        var cust = await db.Customers.AsNoTracking().FirstOrDefaultAsync(x => x.CustomerID == c.CustomerID);
        customerNotes = cust?.Notes ?? "";

        if (!string.IsNullOrWhiteSpace(cust?.LastPriceSheet))
        {
            var match = pricesheets.FirstOrDefault(p => string.Equals(p.PriceSheetName, cust!.LastPriceSheet, StringComparison.OrdinalIgnoreCase));
            if (match != null) selectedPricesheet = match.PriceSheetNumber!;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        var hasPermit = await db.CustomerPermits.AnyAsync(p => p.CustomerId == c.CustomerID && p.ExpirationDate > today);
        permitWarning = !hasPermit;
        salesTaxEnabled = !hasPermit;

        if (!string.IsNullOrEmpty(selectedPricesheet)) await LoadCatalog();
        ComputeTotals();
    }

    private void ClearCustomer()
    {
        selectedCustomerId = null;
        customerName = "";
        selectedPricesheet = "";
        gridRows = new();
        filteredRows = new();
        importedOtid = null;
        permitWarning = false;
    }

    private async Task OnPricesheetChanged()
    {
        if (selectedCustomerId == null || string.IsNullOrEmpty(selectedPricesheet)) return;
        await LoadCatalog();   // re-prices; preserves entered quantities
        ComputeTotals();
    }

    // Builds the priced grid for the selected customer/pricesheet, preserving any
    // quantities already keyed (re-prices unit prices from the new pricesheet).
    private async Task LoadCatalog()
    {
        gridLoading = true;
        var prevQty = gridRows.ToDictionary(r => r.ProductId, r => r.Qty);
        var priced = await Invoices.GetPricedProductsAsync(selectedCustomerId!.Value, selectedPricesheet, orderYear);
        gridRows = priced.Select(p => new InvRow
        {
            ProductId = p.ProductId,
            ItemNumber = p.ItemNumber,
            ProductName = p.ProductName,
            NetItem = p.NetItem,
            UnitPrice = p.UnitPrice,
            Qty = prevQty.TryGetValue(p.ProductId, out var q) ? q : 0
        }).ToList();
        RecomputeFilter();
        gridLoading = false;
    }

    private void RecomputeFilter()
    {
        var f = gridFilter?.Trim();
        filteredRows = gridRows.Where(r =>
            (!onlyEntered || r.Qty > 0)
            && (string.IsNullOrWhiteSpace(f)
                || (r.ItemNumber?.ToString().Contains(f) ?? false)
                || (r.ProductName?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)))
            .ToList();
    }

    private async Task ToggleImport()
    {
        showImport = !showImport;
        if (!showImport) return;
        // Import candidates: this customer's working-year orders pulled/returned/loaded
        // (matches the legacy frmImportOrder filter).
        var yearStr = YearState.Year.ToString();
        await using var db = DbFactory.CreateDbContext();
        importList = await db.OrdersTakens
            .Where(o => o.OrderYear == yearStr
                     && o.CustomerID == selectedCustomerId
                     && (o.Status == "Pulled" || o.Status == "Return" || o.Status == "Loaded"))
            .OrderByDescending(o => o.OrdersTakenID)
            .Select(o => new ImportOption(o.OrdersTakenID, o.Status, o.TypeOrder, o.TimeTaken))
            .ToListAsync();
    }

    private async Task Import(int otid)
    {
        await using var db = DbFactory.CreateDbContext();
        var oTaken = await db.OrdersTakens.FirstOrDefaultAsync(o => o.OrdersTakenID == otid);
        if (oTaken == null) return;

        var details = await db.OrdersTakenDetails
            .Where(d => d.OrdersTakenID == otid)
            .Join(db.Products, d => d.ProductID, p => p.ProductID,
                (d, p) => new { d.ProductID, d.QuantityPulled, p.ItemsPerPack })
            .ToListAsync();

        int added = 0;
        foreach (var d in details)
        {
            if (d.QuantityPulled == null) continue;
            decimal qty = d.QuantityPulled.Value;
            if (oTaken.TypeOrder == "Piece" && (d.ItemsPerPack ?? 0) > 0)
                qty = Math.Round(qty / d.ItemsPerPack!.Value, 4, MidpointRounding.AwayFromZero);
            var qtyInt = (int)Math.Round(qty, MidpointRounding.AwayFromZero);
            if (qtyInt <= 0) continue;

            var row = gridRows.FirstOrDefault(r => r.ProductId == d.ProductID);
            if (row != null) { row.Qty += qtyInt; added++; }
        }

        oTaken.Status = "Imported";
        await db.SaveChangesAsync();

        importedOtid = otid;
        showImport = false;
        RecomputeFilter();
        ComputeTotals();
        statusMessage = $"Imported {added} item(s) from order #{otid}.";
        isError = false;
    }

    private void ComputeTotals()
    {
        netItemsTotal = gridRows.Where(r => r.NetItem).Sum(r => r.Extended);
        itemsTotal = gridRows.Where(r => !r.NetItem).Sum(r => r.Extended);
        var subtotal = netItemsTotal + itemsTotal + misc;

        salesTax = 0m;
        if (salesTaxEnabled && subtotal >= 0m)
        {
            // Legacy frmNewOrder tax base: misc + (net + items + misc). Preserved as-is.
            salesTax = Math.Round((misc + subtotal) * taxRate, 2, MidpointRounding.AwayFromZero);
        }

        total = subtotal + salesTax + license + insurance;
    }

    private async Task Post()
    {
        if (selectedCustomerId == null || string.IsNullOrEmpty(selectedPricesheet))
        {
            isError = true; statusMessage = "Select a customer and pricesheet."; return;
        }
        var qtyRows = gridRows.Where(r => r.Qty > 0).ToList();
        if (!qtyRows.Any()) { isError = true; statusMessage = "Enter a quantity for at least one item."; return; }

        isBusy = true;
        try
        {
            ComputeTotals();

            var header = new InvoiceService.InvoiceHeader(
                OrderId: OrderId, CustomerId: selectedCustomerId.Value, PriceSheetNumber: selectedPricesheet,
                OrderTotal: total, LicenseCharges: license, InsuranceCharges: insurance, MiscCharges: misc,
                NetTotal: netItemsTotal, OrderYear: orderYear, OrdersTakenId: importedOtid,
                SalesTax: salesTax, ChargeText: chargeText ?? "", Comment: "");

            var orderId = await Invoices.SaveHeaderAsync(header);

            foreach (var r in qtyRows)
                await Invoices.SaveLineAsync(orderId, r.ProductId, r.Qty, r.UnitPrice);

            // Remove lines that existed before but were cleared.
            var keep = qtyRows.Select(r => r.ProductId).ToHashSet();
            foreach (var pid in originalLineProductIds.Where(p => !keep.Contains(p)))
                await Invoices.DeleteLineAsync(orderId, pid);

            // Warehouse-order linkage.
            if (importedOtid != null)
            {
                await Invoices.SetLinkedOrdersTakenIdAsync(orderId, importedOtid.Value);
            }
            else
            {
                var existing = await Invoices.GetLinkedOrdersTakenIdAsync(orderId);
                if (existing is > 0) await Invoices.UpdateOrdersTakenFromOrderAsync(orderId);
                else await Invoices.CreateOrdersTakenFromOrderAsync(orderId);
            }

            await UpdateCustomerInfo();

            // Render and cache the invoice document HTML to Orders.Invoice.
            try { await Invoices.GenerateAndSaveInvoiceHtmlAsync(orderId); }
            catch { /* invoice is saved; the document regenerates whenever it is opened */ }

            if (OrderId == null)
            {
                Nav.NavigateTo($"/invoices/{orderId}");
            }
            else
            {
                await LoadExisting();
                statusMessage = $"Invoice #{orderId} posted.";
                isError = false;
            }
        }
        catch (Exception ex)
        {
            isError = true; statusMessage = $"Error posting invoice: {ex.Message}";
        }
        finally { isBusy = false; }
    }

    private async Task UpdateCustomerInfo()
    {
        await using var db = DbFactory.CreateDbContext();
        var cust = await db.Customers.FirstOrDefaultAsync(c => c.CustomerID == selectedCustomerId);
        if (cust == null) return;
        var name = pricesheets.FirstOrDefault(p => p.PriceSheetNumber == selectedPricesheet)?.PriceSheetName;
        cust.LastPriceSheet = name;
        cust.LastInvoiceYear = DateTime.Today.Year.ToString();
        cust.Notes = customerNotes;
        await db.SaveChangesAsync();
    }

    private async Task Delete()
    {
        if (OrderId == null) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete invoice #{OrderId}?")) return;
        isBusy = true;
        try
        {
            await Invoices.DeleteInvoiceAsync(OrderId.Value);
            Nav.NavigateTo("/invoices");
        }
        catch (Exception ex) { isError = true; statusMessage = $"Error deleting: {ex.Message}"; isBusy = false; }
    }
}
