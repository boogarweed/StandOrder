@page "/reports/sales"
@rendermode InteractiveServer
@using System.Text
@using StandOrder.Models
@using FWOffice.Services
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject WorkingYearState YearState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Sales Reports</PageTitle>

<h1 class="mb-3 d-print-none">Sales Reports</h1>

@* Report chooser — panels 3-across; nothing runs until clicked. *@
<div class="row g-3 mb-4 d-print-none">
    @foreach (var r in Reports)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 @(activeReport == r.Key ? "border-primary" : "")">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@r.Title</h5>
                    <p class="card-text text-muted small flex-grow-1">@r.Description</p>
                    <button class="btn @(activeReport == r.Key ? "btn-primary" : "btn-outline-primary") align-self-start"
                            @onclick="() => RunReportPanel(r.Key)">Run report</button>
                </div>
            </div>
        </div>
    }
</div>

@if (activeReport == "summary")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Sales Summary</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Every order for @year@(summaryRows.Any() ? $" ({summaryRows.Count})" : "").</div>
                @if (summaryRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportSummaryExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Orders by Customer <span class="text-muted fs-6">(@year)</span></h4>
            @if (summaryLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!summaryRows.Any())
            {
                <p class="text-muted">No orders for @year.</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Customer Name</th>
                            <th>Number</th>
                            <th>Order</th>
                            <th>Date</th>
                            <th>Terms</th>
                            <th class="text-end">Non-Net</th>
                            <th class="text-end">Net</th>
                            <th class="text-end">Discount</th>
                            <th class="text-end">Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in summaryRows)
                        {
                            <tr>
                                <td>@r.CustomerName</td>
                                <td>@r.Number</td>
                                <td>@r.Order</td>
                                <td>@(r.Date?.ToString("MM/dd/yyyy"))</td>
                                <td>@r.Terms</td>
                                <td class="text-end">@r.NonNet.ToString("C2")</td>
                                <td class="text-end">@r.Net.ToString("C2")</td>
                                <td class="text-end">@((r.Discount * 100).ToString("0.##"))%</td>
                                <td class="text-end">@r.Final.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "items")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Items Sold</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Cases sold per item in @year@(itemsRows.Any() ? $" ({itemsRows.Count})" : "").</div>
                @if (itemsRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportItemsExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Items Sold This Year <span class="text-muted fs-6">(@year)</span></h4>
            @if (itemsLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!itemsRows.Any())
            {
                <p class="text-muted">No items sold in @year.</p>
            }
            else
            {
                <table class="table table-striped table-bordered" style="max-width: 44rem;">
                    <thead><tr><th>Item Number</th><th>Product Name</th><th class="text-end">Cases Sold</th></tr></thead>
                    <tbody>
                        @foreach (var r in itemsRows)
                        {
                            <tr>
                                <td>@r.ItemNumber</td>
                                <td>@r.ProductName</td>
                                <td class="text-end">@r.CasesSold.ToString("0.###")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "byitem")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Sales by Item</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Quantity sold per item for orders dated in @year@(byItemRows.Any() ? $" ({byItemRows.Count})" : "").</div>
                @if (byItemRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportByItemExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Sales by Item <span class="text-muted fs-6">(@year)</span></h4>
            @if (byItemLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!byItemRows.Any())
            {
                <p class="text-muted">No sales for @year.</p>
            }
            else
            {
                <table class="table table-striped table-bordered" style="max-width: 44rem;">
                    <thead><tr><th>Item Number</th><th>Product Name</th><th class="text-end">Qty</th></tr></thead>
                    <tbody>
                        @foreach (var r in byItemRows)
                        {
                            <tr>
                                <td>@r.ItemNumber</td>
                                <td>@r.ProductName</td>
                                <td class="text-end">@r.Qty.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "category")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Sales by Category</div>
        <div class="card-body">
            <div class="mb-3 d-print-none" style="max-width: 30rem;">
                <label class="form-label">Category</label>
                <select class="form-select" @bind="selectedCategory" @bind:after="BuildCategoryReport">
                    <option value="">-- Select a category --</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>

            @if (catBuilding)
            {
                <p><em>Building…</em></p>
            }
            else if (!string.IsNullOrEmpty(catError))
            {
                <div class="alert alert-danger">Error building the report: @catError</div>
            }
            else if (!string.IsNullOrEmpty(catHtml))
            {
                <iframe srcdoc="@catHtml" style="width: 100%; height: 80vh; border: 1px solid #dee2e6;"></iframe>
            }
            else if (!string.IsNullOrEmpty(selectedCategory))
            {
                <p class="text-muted">No data for @selectedCategory.</p>
            }
            else
            {
                <p class="text-muted">Choose a category to see its seasonal sales curve and lifetime top sellers.</p>
            }
        </div>
    </div>
}

@* Additional sales reports will be added below as further panels/cards. *@

@code {
    private int year;
    private string? activeReport;

    private record ReportDef(string Key, string Title, string Description);
    private static readonly ReportDef[] Reports = new[]
    {
        new ReportDef("summary", "Sales Summary",
            "Every order in the working year: customer, terms, net/non-net split, discount, and final total."),
        new ReportDef("items", "Items Sold",
            "Total cases sold per item in the working year."),
        new ReportDef("byitem", "Sales by Item",
            "Total quantity sold per item for orders dated in the working year."),
        new ReportDef("category", "Sales by Category",
            "Seasonal daily-average sales curve (Jun 15 – Jul 4) for a chosen category, plus its lifetime top 10."),
    };

    private bool summaryLoading;
    private List<SumRow> summaryRows = new();
    private record SumRow(string? CustomerName, int Number, int Order, DateTime? Date, string? Terms,
        decimal NonNet, decimal Net, decimal Discount, decimal Final);

    private bool itemsLoading;
    private List<ItemRow> itemsRows = new();
    private record ItemRow(int ItemNumber, string? ProductName, decimal CasesSold);

    private bool byItemLoading;
    private List<ByItemRow> byItemRows = new();
    private record ByItemRow(int ItemNumber, string? ProductName, decimal Qty);

    // Sales by Category (chart + top-10, rendered as an HTML doc in an iframe)
    private List<string> categories = new();
    private string selectedCategory = "";
    private bool catBuilding;
    private string catHtml = "";
    private string catError = "";

    protected override void OnInitialized()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        if (activeReport == "summary") await LoadSalesSummary();
        else if (activeReport == "items") await LoadItemsSold();
        else if (activeReport == "byitem") await LoadSalesByItem();
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    private async Task RunReportPanel(string key)
    {
        activeReport = key;
        if (key == "summary") await LoadSalesSummary();
        else if (key == "items") await LoadItemsSold();
        else if (key == "byitem") await LoadSalesByItem();
        else if (key == "category") { await LoadCategories(); selectedCategory = ""; catHtml = ""; }
    }

    private async Task LoadSalesSummary()
    {
        summaryLoading = true;
        var list = new List<SumRow>();
        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT FullName, CustomerID, OrderID, OrderDate, PriceSheetName, OrderTotal, NetTotal, Discount " +
            "FROM vOrdersByCustomer WHERE OrderYear = @yr ORDER BY FullName, OrderID", con))
        {
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var orderTotal = rdr["OrderTotal"] as decimal? ?? 0m;
                var netTotal = rdr["NetTotal"] as decimal? ?? 0m;
                var disc = rdr["Discount"] is DBNull ? 0m : Convert.ToDecimal(rdr["Discount"]);
                list.Add(new SumRow(
                    rdr["FullName"] as string,
                    (int)rdr["CustomerID"],
                    (int)rdr["OrderID"],
                    rdr["OrderDate"] as DateTime?,
                    rdr["PriceSheetName"] as string,
                    orderTotal - netTotal,
                    netTotal,
                    disc,
                    orderTotal));
            }
        }
        summaryRows = list;
        summaryLoading = false;
    }

    private async Task LoadItemsSold()
    {
        itemsLoading = true;
        var list = new List<ItemRow>();
        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT ItemNumber, ProductName, Qty FROM vRptSumQty WHERE ProductYear = @yr ORDER BY ItemNumber", con))
        {
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var qty = rdr["Qty"] is DBNull ? 0m : Math.Round(Convert.ToDecimal(rdr["Qty"]), 3);
                list.Add(new ItemRow(rdr["ItemNumber"] as int? ?? 0, rdr["ProductName"] as string, qty));
            }
        }
        itemsRows = list;
        itemsLoading = false;
    }

    // ---- Sales by Category ----
    private async Task LoadCategories()
    {
        if (categories.Any()) return;   // load once per page instance
        var list = new List<string>();
        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT Category FROM vNormalizedQty WHERE Category IS NOT NULL AND LTRIM(RTRIM(Category)) <> '' " +
            "GROUP BY Category ORDER BY Category", con))
        {
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync()) list.Add(rdr.GetString(0));
        }
        categories = list;
    }

    private async Task BuildCategoryReport()
    {
        catHtml = ""; catError = "";
        if (string.IsNullOrEmpty(selectedCategory)) return;
        catBuilding = true;
        try
        {
            var chart = new List<(string date, double qty)>();
            var top10 = new List<(string name, double qty)>();
            await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
            {
                await con.OpenAsync();

                // Seasonal daily-average curve across all years, for the 06-15..07-04 window.
                const string mmdd = "CONCAT(RIGHT('00'+CONVERT(NVARCHAR(2),DATEPART(MM,orderdate)),2),'-',RIGHT('00'+CONVERT(NVARCHAR(2),DATEPART(DD,orderdate)),2))";
                await using (var cmd = new SqlCommand(
                    $"SELECT AVG(Quantity) AS Quantity, {mmdd} AS SaleDate FROM " +
                    $"(SELECT SUM(OrderQty) AS Quantity, OrderDate FROM vNormalizedQty WHERE category=@cat " +   // OrderQty = normalized cases
                    $"AND {mmdd} BETWEEN '06-15' AND '07-04' GROUP BY OrderDate) myq " +
                    $"GROUP BY {mmdd} ORDER BY SaleDate", con))
                {
                    cmd.Parameters.AddWithValue("@cat", selectedCategory);
                    await using var rdr = await cmd.ExecuteReaderAsync();
                    while (await rdr.ReadAsync())
                        chart.Add((rdr["SaleDate"] as string ?? "", rdr["Quantity"] is DBNull ? 0 : Convert.ToDouble(rdr["Quantity"])));
                }

                // Lifetime (last 5 years) top 10 sellers in the category.
                await using (var cmd2 = new SqlCommand(
                    "SELECT TOP 10 ProductName, SUM(OrderQty) AS Quantity FROM vNormalizedQty " +   // OrderQty = normalized cases
                    "WHERE Category=@cat AND ISDATE(OrderDate)=1 AND CAST(OrderDate AS datetime) > @since " +   // DB is compat 100; no TRY_CONVERT
                    "GROUP BY ProductName ORDER BY Quantity DESC", con))
                {
                    cmd2.Parameters.AddWithValue("@cat", selectedCategory);
                    cmd2.Parameters.AddWithValue("@since", DateTime.Today.AddYears(-5));
                    await using var rdr = await cmd2.ExecuteReaderAsync();
                    while (await rdr.ReadAsync())
                        top10.Add((rdr["ProductName"] as string ?? "", rdr["Quantity"] is DBNull ? 0 : Convert.ToDouble(rdr["Quantity"])));
                }
            }

            if (chart.Any() || top10.Any())
                catHtml = BuildCategoryHtml(selectedCategory, chart, top10);
        }
        catch (Exception ex) { catError = ex.Message; }
        finally { catBuilding = false; }
    }

    private static string BuildCategoryHtml(string category, List<(string date, double qty)> chart, List<(string name, double qty)> top10)
    {
        string Enc(string s) => System.Net.WebUtility.HtmlEncode(s);
        string Num(double d) => d.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
        var labels = string.Join(",", chart.Select(p => $"'{p.date}'"));
        var data = string.Join(",", chart.Select(p => Num(p.qty)));

        var sb = new StringBuilder();
        sb.Append("<!DOCTYPE html><html><head><meta charset='utf-8'>");
        sb.Append("<script src='https://cdn.jsdelivr.net/npm/chart.js'></script>");
        sb.Append("<style>body{font-family:-apple-system,'Segoe UI',Roboto,Arial,sans-serif;margin:1rem;color:#212529;}");
        sb.Append("h1{font-size:1.3rem;margin:.2rem 0;} table{border-collapse:collapse;width:100%;max-width:40rem;margin-top:.5rem;}");
        sb.Append("th,td{border:1px solid #dee2e6;padding:.35rem .5rem;text-align:left;} th{background:#f1f3f5;} tr:nth-child(even) td{background:#f8f9fa;}</style>");
        sb.Append("</head><body>");
        sb.Append($"<h1>Sales by Category — {Enc(category)} <span style='font-weight:normal;color:#6c757d;font-size:1rem'>(avg daily quantity, Jun 15 – Jul 4)</span></h1>");
        sb.Append("<p><a href='#' onclick='window.print();return false;'>Print</a></p>");
        sb.Append("<canvas id='c' height='110'></canvas>");
        sb.Append("<script>new Chart(document.getElementById('c'),{type:'line',data:{labels:[" + labels + "],");
        sb.Append("datasets:[{label:'Avg quantity',data:[" + data + "],borderColor:'#c0392b',backgroundColor:'rgba(192,57,43,.12)',fill:true,tension:.3,pointRadius:2}]},");
        sb.Append("options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,title:{display:true,text:'Avg quantity'}},x:{title:{display:true,text:'Date'}}}}});</script>");
        sb.Append("<hr><h1>Top Ten Sellers (Lifetime)</h1>");
        sb.Append("<table><tr><th>Product Name</th><th>Quantity</th></tr>");
        foreach (var t in top10)
            sb.Append($"<tr><td>{Enc(t.name)}</td><td>{Num(t.qty)}</td></tr>");
        sb.Append("</table></body></html>");
        return sb.ToString();
    }

    private async Task LoadSalesByItem()
    {
        byItemLoading = true;
        var list = new List<ByItemRow>();
        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT ItemNumber, ProductName, SUM(Qty) AS Qty FROM vItemsSoldByDate " +
            "WHERE YEAR(OrderDate) = @yr GROUP BY ItemNumber, ProductName ORDER BY ItemNumber", con))
        {
            cmd.Parameters.AddWithValue("@yr", year);   // YEAR(OrderDate) = calendar year (matches legacy)
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var qty = rdr["Qty"] is DBNull ? 0m : Math.Round(Convert.ToDecimal(rdr["Qty"]), 2);
                list.Add(new ByItemRow(rdr["ItemNumber"] as int? ?? 0, rdr["ProductName"] as string, qty));
            }
        }
        byItemRows = list;
        byItemLoading = false;
    }

    private async Task ExportByItemExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Item Number,Product Name,Qty");
        foreach (var r in byItemRows)
            sb.AppendLine($"{r.ItemNumber},{Csv(r.ProductName)},{r.Qty:0.00}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());
        await JS.InvokeVoidAsync("fwDownload", $"SalesByItem_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private async Task ExportItemsExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Item Number,Product Name,Cases Sold");
        foreach (var r in itemsRows)
            sb.AppendLine($"{r.ItemNumber},{Csv(r.ProductName)},{r.CasesSold:0.###}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());
        await JS.InvokeVoidAsync("fwDownload", $"ItemsSold_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private async Task ExportSummaryExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Customer Name,Number,Order,Date,Terms,Non-Net,Net,Discount %,Final");
        foreach (var r in summaryRows)
            sb.AppendLine($"{Csv(r.CustomerName)},{r.Number},{r.Order},{r.Date:MM/dd/yyyy},{Csv(r.Terms)},{r.NonNet:0.00},{r.Net:0.00},{(r.Discount * 100):0.##},{r.Final:0.00}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());   // BOM so Excel detects UTF-8
        await JS.InvokeVoidAsync("fwDownload", $"SalesSummary_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private static string Csv(string? value)
    {
        var v = value ?? "";
        return (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            ? "\"" + v.Replace("\"", "\"\"") + "\""
            : v;
    }
}
