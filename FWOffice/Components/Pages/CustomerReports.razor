    // ---- Report 3: Check Balances (password-gated) ----
    private async Task CheckKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitCheckPassword();
    }

    private async Task SubmitCheckPassword()
    {
        // Soft gate ported from the legacy report (password "glitter"). Checked server-side.
        if (checkPassword == "glitter")
        {
            checkError = "";
            checkAuthed = true;
            await LoadCheckBalances();
        }
        else
        {
            checkError = "Wrong password.";
        }
    }

    private async Task LoadCheckBalances()
    {
        checkLoading = true;
        checkAsOf = DateTime.Now;

        var order = new List<int>();
        var byCust = new Dictionary<int, (string? Name, List<CheckLine> Lines)>();

        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT CustomerID, FullName, OrderID, OrderDate, PriceSheetName, Discount, OrderT, PaymentT, SettleType " +
            "FROM vCustomerBalance WHERE [Year] = @yr ORDER BY CustomerID, OrderID", con))
        {
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var cid = (int)rdr["CustomerID"];
                var name = rdr["FullName"] as string;
                var ordT = rdr["OrderT"] as decimal? ?? 0m;
                var payT = rdr["PaymentT"] as decimal? ?? 0m;
                var isPayment = string.Equals(rdr["SettleType"] as string, "Payment", StringComparison.OrdinalIgnoreCase);
                var disc = (rdr["Discount"] as float?) ?? 0f;

                var line = new CheckLine(
                    rdr["OrderID"] as int?,
                    rdr["OrderDate"] as DateTime?,
                    rdr["PriceSheetName"] as string,
                    ordT, payT,
                    isPayment ? -payT : ordT,
                    isPayment,
                    (disc * 100).ToString("0.##") + " %");

                if (!byCust.TryGetValue(cid, out var entry))
                {
                    entry = (name, new List<CheckLine>());
                    byCust[cid] = entry;
                    order.Add(cid);
                }
                entry.Lines.Add(line);
            }
        }

        checkCustomers = order.Select(cid =>
        {
            var (name, lines) = byCust[cid];
            return new CheckCustomer(cid, name, lines,
                lines.Sum(l => l.OrderT), lines.Sum(l => l.PaymentT), lines.Sum(l => l.LineTotal));
        }).ToList();

        checkLoading = false;
    }

    private async Task ExportCheckExcel()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Customer Number,Full Name,Order/Payment ID,Date,Terms,Discount,Order Total,Payment Total,Total");
        foreach (var cust in checkCustomers)
            foreach (var l in cust.Lines)
                sb.AppendLine($"{cust.CustomerId},{Csv(cust.FullName)},{l.OrderPaymentId},{l.Date:MM/dd/yyyy HH:mm},{Csv(l.Terms)},{Csv(l.DiscountDisplay)},{l.OrderT:0.00},{l.PaymentT:0.00},{l.LineTotal:0.00}");

        var bytes = Encoding.UTF8.GetBytes("﻿" + sb.ToString());
        await JS.InvokeVoidAsync("fwDownload", $"CheckBalances_{year}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private static string Csv(string? value)
    {
        var v = value ?? "";
        return (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            ? "\"" + v.Replace("\"", "\"\"") + "\""
            : v;
    }
