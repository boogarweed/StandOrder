        await using var db = DbFactory.CreateDbContext();
        // Project to an anonymous type in SQL, then map to the record in memory
        // (EF can't translate a positional-record constructor with OrderBy).
        var raw = await db.Customers.AsNoTracking()
            .OrderBy(c => c.FullName)
            .Select(c => new { c.CustomerID, c.FullName, c.BillingAddress, c.City, c.StateOrProvince, c.ZIPCode, c.PhoneNumber, c.CellPhoneNumber, c.DateAdded })
            .ToListAsync();
        longRows = raw.Select(c => new LongRow(c.CustomerID, c.FullName, c.BillingAddress, c.City,
            c.StateOrProvince, c.ZIPCode, c.PhoneNumber, c.CellPhoneNumber, c.DateAdded)).ToList();
        longLoading = false;
    }

