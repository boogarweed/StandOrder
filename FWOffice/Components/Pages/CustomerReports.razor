@page "/reports/customer"
@rendermode InteractiveServer
@using System.Text
@using StandOrder.Models
@using Microsoft.EntityFrameworkCore
@using FWOffice.Services
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IConfiguration Configuration
@inject WorkingYearState YearState
@inject YearEndEmailService YearEnd
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Customer Reports</PageTitle>

<h1 class="mb-3 d-print-none">Customer Reports</h1>

@* Report chooser — panels 3-across, wrapping to as many rows as needed. Nothing runs until clicked. *@
<div class="row g-3 mb-4 d-print-none">
    @foreach (var r in Reports)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 @(activeReport == r.Key ? "border-primary" : "")">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@r.Title</h5>
                    <p class="card-text text-muted small flex-grow-1">@r.Description</p>
                    <button class="btn @(activeReport == r.Key ? "btn-primary" : "btn-outline-primary") align-self-start"
                            @onclick="() => RunReportPanel(r.Key)">Run report</button>
                </div>
            </div>
        </div>
    }
</div>

@* ---- Output for the selected report ---- *@
@if (activeReport == "single")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Single Customer Summary</div>
        <div class="card-body">
            <div class="d-flex gap-3 align-items-end flex-wrap mb-3 d-print-none">
                <div class="position-relative" style="max-width: 28rem; flex: 1 1 20rem;">
                    <label class="form-label">Customer <span class="text-danger">*</span></label>
                    @if (selectedCustomerId == null)
                    {
                        <input class="form-control" placeholder="Search customer by name or business..."
                               value="@custSearchText" @oninput="OnCustSearch" />
                        @if (custResults.Any())
                        {
                            <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 300px; overflow-y: auto;">
                                @foreach (var c in custResults)
                                {
                                    <button type="button" class="list-group-item list-group-item-action" @onclick="() => SelectCustomer(c)">
                                        <strong>@c.FullName</strong>
                                        @if (!string.IsNullOrWhiteSpace(c.BusinessName)) { <span class="text-muted"> — @c.BusinessName</span> }
                                    </button>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="input-group">
                            <input class="form-control" value="@customerName" readonly />
                            <button class="btn btn-outline-secondary" @onclick="ClearCustomer">Change</button>
                        </div>
                    }
                </div>
                @if (selectedCustomerId != null && rows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            @if (selectedCustomerId == null)
            {
                <div class="text-muted">Choose a customer to run the report.</div>
            }
            else
            {
                <h4 class="mt-1">Customer Order Detail Report <span class="text-muted fs-6">(@year)</span></h4>
                @if (loading)
                {
                    <p><em>Loading…</em></p>
                }
                else if (!rows.Any())
                {
                    <p class="text-muted">No summary rows for @customerName in @year.</p>
                }
                else
                {
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Full Name</th>
                                <th>Customer<br />Number</th>
                                <th>Item<br />Number</th>
                                <th>Product Name</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Qty Ordered</th>
                                <th class="text-end">Qty Returned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in rows)
                            {
                                <tr>
                                    <td>@r.FullName</td>
                                    <td>@r.CustomerID</td>
                                    <td>@r.ItemNumber</td>
                                    <td>@r.ProductName</td>
                                    <td class="text-end">@r.Quantity</td>
                                    <td class="text-end">@r.QtyOrdered</td>
                                    <td class="text-end">@r.QtyReturned</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </div>
}
else if (activeReport == "balance")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Customers with Balance</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Customers with an outstanding balance in @year.</div>
                @if (balanceRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportBalancesExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Customers with Outstanding Balance <span class="text-muted fs-6">(@year)</span></h4>
            @if (balanceLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!balanceRows.Any())
            {
                <p class="text-muted">No customers with an outstanding balance in @year.</p>
            }
            else
            {
                <table class="table table-striped table-bordered" style="max-width: 40rem;">
                    <thead><tr><th>Full Name</th><th class="text-end">Balance</th></tr></thead>
                    <tbody>
                        @foreach (var b in balanceRows)
                        {
                            <tr><td>@b.FullName</td><td class="text-end">@b.BalanceDisplay</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "summary")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Customer Summary</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Item quantities for every customer in @year@(summaryRows.Any() ? $" ({summaryRows.Count} rows)" : "").</div>
                @if (summaryRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportSummaryExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Customer Order Detail Report <span class="text-muted fs-6">(@year)</span></h4>
            @if (summaryLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!summaryRows.Any())
            {
                <p class="text-muted">No summary rows for @year.</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Customer<br />Number</th>
                            <th>Item<br />Number</th>
                            <th>Product Name</th>
                            <th class="text-end">Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in summaryRows)
                        {
                            <tr>
                                <td>@r.FullName</td>
                                <td>@r.CustomerID</td>
                                <td>@r.ItemNumber</td>
                                <td>@r.ProductName</td>
                                <td class="text-end">@r.Quantity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "check")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Check Balances</div>
        <div class="card-body">
            @if (!checkAuthed)
            {
                <div style="max-width: 22rem;">
                    <label class="form-label">Enter password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" @bind="checkPassword" @bind:event="oninput" @onkeydown="CheckKeyDown" />
                        <button class="btn btn-primary" @onclick="SubmitCheckPassword">Unlock</button>
                    </div>
                    @if (!string.IsNullOrEmpty(checkError))
                    {
                        <div class="text-danger small mt-1">@checkError</div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-start mb-2 d-print-none">
                    <div class="text-muted">Balance summary by customer for @year.</div>
                    @if (checkCustomers.Any())
                    {
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary" @onclick="ExportCheckExcel">Open in Excel</button>
                            <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                        </div>
                    }
                </div>

                <h4 class="mb-0">Balance Summary by Customer</h4>
                <div class="text-muted mb-3">As of @checkAsOf.ToString("MM/dd/yyyy HH:mm") · @year</div>

                @if (checkLoading)
                {
                    <p><em>Loading…</em></p>
                }
                else if (!checkCustomers.Any())
                {
                    <p class="text-muted">No balance activity in @year.</p>
                }
                else
                {
                    @foreach (var cust in checkCustomers)
                    {
                        <div class="mb-4">
                            <h5 class="mb-1">@cust.FullName <span class="text-muted fs-6">(#@cust.CustomerId)</span></h5>
                            <table class="table table-sm table-bordered mb-1">
                                <thead>
                                    <tr>
                                        <th>Order/Payment ID</th><th>Date</th><th>Terms</th><th class="text-end">Discount</th>
                                        <th class="text-end">Order Total</th><th class="text-end">Payment Total</th><th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in cust.Lines)
                                    {
                                        <tr>
                                            <td>@l.OrderPaymentId</td>
                                            <td>@(l.Date?.ToString("MM/dd/yyyy h:mm tt"))</td>
                                            <td>@l.Terms</td>
                                            <td class="text-end">@l.DiscountDisplay</td>
                                            <td class="text-end">@(l.IsPayment ? "" : l.OrderT.ToString("C"))</td>
                                            <td class="text-end">@(l.IsPayment ? l.PaymentT.ToString("C") : "")</td>
                                            <td class="text-end">@l.LineTotal.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-secondary fw-semibold">
                                        <td colspan="4" class="text-end">Totals</td>
                                        <td class="text-end">@cust.OrdersTotal.ToString("C")</td>
                                        <td class="text-end">@cust.PaymentsTotal.ToString("C")</td>
                                        <td class="text-end">@cust.Balance.ToString("C")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                }
            }
        </div>
    </div>
}
else if (activeReport == "long")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Long Customer</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Contact directory for every customer@(longRows.Any() ? $" ({longRows.Count})" : "").</div>
                @if (longRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportLongExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Long Customer Report</h4>
            @if (longLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!longRows.Any())
            {
                <p class="text-muted">No customers.</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr><th style="width: 10rem;">Customer Number</th><th>Customer Info</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in longRows)
                        {
                            <tr>
                                <td>@r.CustomerID</td>
                                <td>
                                    <div>@r.FullName</div>
                                    <div>@r.BillingAddress</div>
                                    <div>@r.City, @r.StateOrProvince @r.ZIPCode</div>
                                    <div>Phone: @r.PhoneNumber Cell: @r.CellPhoneNumber</div>
                                    <div>Date Added: @(r.DateAdded?.ToString("MM/dd/yyyy"))</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "unseen")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold d-print-none">Unseen Customers</div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2 d-print-none">
                <div class="text-muted">Invoiced in @(year - 1) but not yet in @year@(unseenRows.Any() ? $" ({unseenRows.Count})" : "").</div>
                @if (unseenRows.Any())
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ExportUnseenExcel">Open in Excel</button>
                        <button class="btn btn-outline-secondary" onclick="window.print()">Print</button>
                    </div>
                }
            </div>

            <h4 class="mt-1">Unseen Customers <span class="text-muted fs-6">(last invoiced @(year - 1))</span></h4>
            @if (unseenLoading)
            {
                <p><em>Loading…</em></p>
            }
            else if (!unseenRows.Any())
            {
                <p class="text-muted">No customers were last invoiced in @(year - 1).</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr><th>Customer</th><th>Email</th><th>Phone</th><th>Cell</th><th>Notes</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in unseenRows)
                        {
                            <tr>
                                <td>@r.Customer</td>
                                <td>@r.Email</td>
                                <td>@r.Phone</td>
                                <td>@r.Cell</td>
                                <td>@r.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (activeReport == "email")
{
    <div class="card mb-4">
        <div class="card-header fw-semibold">Year-End Email</div>
        <div class="card-body">
            <div class="mb-3 position-relative" style="max-width: 28rem;">
                <label class="form-label">Customer <span class="text-danger">*</span></label>
                @if (selectedCustomerId == null)
                {
                    <input class="form-control" placeholder="Search customer by name or business..."
                           value="@custSearchText" @oninput="OnCustSearch" />
                    @if (custResults.Any())
                    {
                        <div class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 300px; overflow-y: auto;">
                            @foreach (var c in custResults)
                            {
                                <button type="button" class="list-group-item list-group-item-action" @onclick="() => SelectCustomer(c)">
                                    <strong>@c.FullName</strong>
                                    @if (!string.IsNullOrWhiteSpace(c.BusinessName)) { <span class="text-muted"> — @c.BusinessName</span> }
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="input-group">
                        <input class="form-control" value="@customerName" readonly />
                        <button class="btn btn-outline-secondary" @onclick="ClearCustomer">Change</button>
                    </div>
                }
            </div>

            @if (selectedCustomerId != null)
            {
                <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                    <button class="btn btn-primary" @onclick="GenerateEmail" disabled="@emailBusy">
                        @(emailBusy ? "Generating…" : (string.IsNullOrEmpty(emailText) ? "Generate email" : "Regenerate"))
                    </button>
                    <span class="text-muted">Recipient: @(string.IsNullOrWhiteSpace(emailAddress) ? "(no email on file)" : emailAddress) · @year</span>
                </div>

                @if (emailBusy)
                {
                    <p class="text-muted"><em>Contacting the local AI — a full year-end email can take a minute…</em></p>
                }
                @if (!string.IsNullOrEmpty(emailError))
                {
                    <div class="alert alert-danger">@emailError</div>
                }
                @if (!string.IsNullOrEmpty(emailText))
                {
                    <label class="form-label">Generated email — review and edit before sending</label>
                    <textarea class="form-control" style="min-height: 26rem;" @bind="emailText"></textarea>
                    <div class="mt-2 d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary" @onclick="CopyEmail">Copy</button>
                        @if (copied) { <span class="text-success small">Copied to clipboard</span> }
                    </div>

                    @if (referencedProducts.Any())
                    {
                        var missing = referencedProducts.Where(p => !p.InData).ToList();
                        <div class="mt-3">
                            <div class="fw-semibold">Products referenced in this email</div>
                            @if (missing.Any())
                            {
                                <div class="alert alert-danger py-2 my-1">
                                    <strong>⚠ @missing.Count not found in the data.</strong> Do not send until you verify or remove them.
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small mb-1">All in the data — confirm each is under the right category before sending.</div>
                            }
                            <table class="table table-sm" style="max-width: 46rem;">
                                <thead><tr><th>Product</th><th>Category in data</th></tr></thead>
                                <tbody>
                                    @foreach (var p in referencedProducts)
                                    {
                                        <tr class="@(p.InData ? "" : "table-danger")">
                                            <td>@p.Name</td>
                                            <td>@(p.InData ? p.Category : "NOT IN DATA")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            }
        </div>
    </div>
}

@code {
    private int year;
    private string? activeReport;   // null = nothing run yet; "single" / "balance"

    private record ReportDef(string Key, string Title, string Description);
    private static readonly ReportDef[] Reports = new[]
    {
        new ReportDef("single", "Single Customer Summary",
            "Item-level quantity, ordered, and returned for one customer in the working year."),
        new ReportDef("summary", "Customer Summary",
            "Item-level quantities for every customer in the working year."),
        new ReportDef("balance", "Customers with Balance",
            "Every customer with an outstanding balance in the working year."),
        new ReportDef("check", "Check Balances",
            "Password-protected. Full balance summary by customer: every order and payment with per-customer totals."),
        new ReportDef("long", "Long Customer",
            "Contact directory for every customer: address, phone, and date added."),
        new ReportDef("unseen", "Unseen Customers",
            "Customers invoiced last year but not yet this year — a follow-up contact list."),
        new ReportDef("email", "Year-End Email",
            "Generate a personalized year-end summary email for a customer with the local AI."),
    };

    // ---- Report 1 state ----
    private bool loading;
    private int? selectedCustomerId;
    private string customerName = "";
    private string custSearchText = "";
    private List<Customer> custResults = new();
    private List<Row> rows = new();
    private record Row(string? FullName, int CustomerID, int? ItemNumber, string? ProductName,
        string Quantity, string QtyOrdered, string QtyReturned);

    // ---- Report: Customer Summary (all customers) ----
    private bool summaryLoading;
    private List<SumRow> summaryRows = new();
    private record SumRow(string? FullName, int CustomerID, int? ItemNumber, string? ProductName, string Quantity);

    // ---- Report: Long Customer (contact directory, not year-scoped) ----
    private bool longLoading;
    private List<LongRow> longRows = new();
    private record LongRow(int CustomerID, string? FullName, string? BillingAddress, string? City,
        string? StateOrProvince, string? ZIPCode, string? PhoneNumber, string? CellPhoneNumber, DateTime? DateAdded);

    // ---- Report: Unseen Customers (last invoiced in year-1) ----
    private bool unseenLoading;
    private List<UnseenRow> unseenRows = new();
    private record UnseenRow(string? Customer, string? Email, string? Phone, string? Cell, string? Notes);

    // ---- Report: Year-End Email (local AI) ----
    private bool emailBusy;
    private string emailAddress = "";
    private string emailText = "";
    private string emailError = "";
    private bool copied;
    private List<ProductRef> referencedProducts = new();

    // ---- Report 2 state ----
    private bool balanceLoading;
    private List<BalRow> balanceRows = new();
    private record BalRow(string? FullName, decimal Balance, string BalanceDisplay);

    // ---- Report 3 state (Check Balances) ----
    private bool checkAuthed;
    private string checkPassword = "";
    private string checkError = "";
    private bool checkLoading;
    private DateTime checkAsOf;
    private List<CheckCustomer> checkCustomers = new();
    private record CheckLine(int? OrderPaymentId, DateTime? Date, string? Terms, decimal OrderT, decimal PaymentT,
        decimal LineTotal, bool IsPayment, string DiscountDisplay);
    private record CheckCustomer(int CustomerId, string? FullName, List<CheckLine> Lines,
        decimal OrdersTotal, decimal PaymentsTotal, decimal Balance);

    protected override void OnInitialized()
    {
        year = YearState.Year;
        YearState.OnChange += HandleYearChange;
    }

    private void HandleYearChange() => InvokeAsync(async () =>
    {
        year = YearState.Year;
        if (activeReport == "balance") await LoadBalances();
        else if (activeReport == "summary") await LoadCustomerSummary();
        else if (activeReport == "unseen") await LoadUnseen();
        else if (activeReport == "single" && selectedCustomerId != null) await RunReport();
        else if (activeReport == "check" && checkAuthed) await LoadCheckBalances();
        StateHasChanged();
    });

    public void Dispose() => YearState.OnChange -= HandleYearChange;

    private async Task RunReportPanel(string key)
    {
        activeReport = key;
        if (key == "balance") await LoadBalances();
        else if (key == "summary") await LoadCustomerSummary();
        else if (key == "long") await LoadLongCustomers();
        else if (key == "unseen") await LoadUnseen();
        else if (key == "email") { emailText = ""; emailError = ""; copied = false; referencedProducts = new(); }  // reveals the picker
        else if (key == "check") { checkAuthed = false; checkPassword = ""; checkError = ""; }  // prompt each time
        // "single" just reveals the customer picker; the report runs once a customer is chosen.
    }

    // ---- Report 1: Single Customer Summary ----
    private async Task OnCustSearch(ChangeEventArgs e)
    {
        custSearchText = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(custSearchText)) { custResults = new(); return; }
        var term = custSearchText.Trim();
        await using var db = DbFactory.CreateDbContext();
        custResults = await db.Customers
            .Where(c => (c.FullName != null && c.FullName.Contains(term))
                     || (c.LastName != null && c.LastName.Contains(term))
                     || (c.BusinessName != null && c.BusinessName.Contains(term)))
            .OrderBy(c => c.LastName).Take(25).AsNoTracking().ToListAsync();
    }

    private async Task SelectCustomer(Customer c)
    {
        selectedCustomerId = c.CustomerID;
        customerName = c.FullName ?? "";
        emailAddress = c.Email ?? "";
        custResults = new();
        custSearchText = "";
        emailText = ""; emailError = ""; copied = false; referencedProducts = new();
        if (activeReport == "single") await RunReport();   // email waits for the Generate button
    }

    private void ClearCustomer()
    {
        selectedCustomerId = null;
        customerName = "";
        rows = new();
        emailAddress = ""; emailText = ""; emailError = ""; copied = false; referencedProducts = new();
    }

    private async Task RunReport()
    {
        if (selectedCustomerId == null) return;
        loading = true;
        var list = new List<Row>();

        await using (var con = new SqlConnection(Configuration.GetConnectionString("DefaultConnection")))
        await using (var cmd = new SqlCommand(
            "SELECT CustomerID, FullName, ItemNumber, ProductName, Quantity, QtyOrdered, QtyReturned, CaseQty, PacksPerCase, PackName " +
            "FROM vCustomerSummary WHERE ProductYear = @yr AND CustomerID = @cid ORDER BY FullName, ItemNumber", con))
        {
            cmd.Parameters.AddWithValue("@yr", year.ToString());
            cmd.Parameters.AddWithValue("@cid", selectedCustomerId.Value);
            await con.OpenAsync();
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
            {
                var caseQty = rdr["CaseQty"] as string;
                var ppc = rdr["PacksPerCase"] as int?;
                var packName = rdr["PackName"] as string;
                list.Add(new Row(
                    rdr["FullName"] as string,
                    (int)rdr["CustomerID"],
                    rdr["ItemNumber"] as int?,
                    rdr["ProductName"] as string,
                    Qty(rdr["Quantity"] as double?, caseQty, ppc, packName),
                    Qty(rdr["QtyOrdered"] as double?, caseQty, ppc, packName),
                    Qty(rdr["QtyReturned"] as double?, caseQty, ppc, packName)));
            }
        }

        rows = list;
        loading = false;
    }

    // Legacy display: Case orders show "<qty> cs"; otherwise "<qty*PacksPerCase> <PackName>".
    private static string Qty(double? qty, string? caseQty, int? packsPerCase, string? packName)
    {
        var q = qty ?? 0;
        var isCase = (caseQty ?? "").Trim() == "Y";
        var value = isCase ? q : q * (packsPerCase ?? 0);
        var unit = isCase ? "cs" : (packName ?? "");
        var num = value % 1 == 0 ? ((long)value).ToString() : value.ToString("0.##");
        return $"{num} {unit}".Trim();
    }

