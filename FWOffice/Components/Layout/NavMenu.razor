<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FW Office</a>
    </div>
</div>

<WorkingYearSelector />

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column fw-nav">
        @foreach (var node in Menu)
        {
            <NavTreeItem Node="node" />
        }
    </nav>
</div>

@code {
    // The office navigation tree. Live pages set Enabled + Href; everything
    // else renders as a "soon" placeholder until its screen is built.
    // Edit/Print are reached from within a Browse list page, so they are not
    // navigation entries here.
    private static readonly List<NavNode> Menu = new()
    {
        new NavNode("Invoices", Children: new()
        {
            new NavNode("Browse", Href: "invoices", Enabled: true),
            new NavNode("New", Href: "invoices/new", Enabled: true),
        }),
        new NavNode("Payments", Children: new()
        {
            new NavNode("Browse"),
            new NavNode("New"),
            new NavNode("Payment Types"),
        }),
        new NavNode("Orders", Children: new()
        {
            new NavNode("Browse", Href: "orders", Enabled: true),
            new NavNode("Add Order", Href: "orders/new", Enabled: true),
            new NavNode("Back Orders", Href: "orders/backorders", Enabled: true),
        }),
        new NavNode("Products", Children: new()
        {
            new NavNode("Browse", Href: "products", Enabled: true),
            new NavNode("Trucks", Children: new()
            {
                new NavNode("Browse", Href: "trucks", Enabled: true),
                new NavNode("New", Href: "trucks/receive", Enabled: true),
                new NavNode("Truck Report", Href: "trucks/report", Enabled: true),
            }),
            new NavNode("Inventory Update", Href: "products/inventory", Enabled: true),
            new NavNode("Import/Export"),
        }),
        new NavNode("Customers", Expanded: true, Children: new()
        {
            new NavNode("Browse", Href: "customers", Enabled: true),
            new NavNode("Permits", Href: "permits", Enabled: true),
            new NavNode("Statement", Href: "statement", Enabled: true),
            new NavNode("Email", Children: new()
            {
                new NavNode("List"),
                new NavNode("Price Sheets"),
            }),
        }),
        new NavNode("Calendar", Href: "calendar", Enabled: true),
        new NavNode("Reports", Children: new()
        {
            new NavNode("Customer"),
            new NavNode("Sales"),
            new NavNode("End of Season"),
            new NavNode("Trucks"),
            new NavNode("Miscellaneous"),
        }),
        new NavNode("Settings", Href: "settings", Enabled: true),
    };
}
